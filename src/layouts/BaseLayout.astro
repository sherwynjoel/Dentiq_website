---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Best Dental Hospital in Erode | DentiQ Superspeciality',
  description = 'DentiQ Superspeciality Laser Dental Hospital in Palayapalayam, Erode. Expert dental team providing 5-star comfort and world-class sterile dental care.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=Outfit:wght@400;600;800&display=swap"
    />
  </head>
  <body class="is-loading">
    <!-- Sticky Booking Sidebar -->
    <a href="#contact" class="sticky-sidebar">Book Appointment</a>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Design Tokens ─────────────────────────────────────────── */
  :root {
    --clr-navy:        #4e4832; /* Derived deep olive brown for high contrast */
    --clr-navy-mid:    #6b6445; /* Dark Muddy/Olive Brown from palette */
    --clr-navy-light:  #707e57; /* Muted Sage Green from palette */
    --clr-gold:        #cec4a7; /* Warm Tan from palette replacing Gold */
    --clr-gold-light:  #d8cfb3; /* Slightly lighter Tan */
    --clr-gold-dark:   #9c8f6f; /* Darker tan for readable text on light backgrounds */
    --clr-gold-pale:   rgba(206, 196, 167, 0.15); /* Tan pale */
    --clr-white:       #fcfaf6; /* Very warm white */
    --clr-off-white:   #ebe6d6; /* Light Creamy Beige from palette */
    --clr-light-gray:  #ded5b9; /* Lighter Beige/Sand from palette */
    --clr-text-dark:   #4e4832;
    --clr-text-mid:    #6b6445;
    --clr-text-body:   #5b543c;
    --clr-text-light:  rgba(255, 255, 255, 0.85);

    --font-heading: 'Outfit', 'Jost', system-ui, sans-serif;
    --font-body:    'Jost', system-ui, sans-serif;

    --text-xs:   clamp(0.72rem, 1.4vw, 0.82rem);
    --text-sm:   clamp(0.88rem, 1.7vw, 0.97rem);
    --text-base: clamp(1rem,    2vw,   1.08rem);
    --text-lg:   clamp(1.12rem, 2.2vw, 1.28rem);
    --text-xl:   clamp(1.3rem,  2.6vw, 1.6rem);
    --text-2xl:  clamp(1.8rem,  3.6vw, 2.5rem);
    --text-3xl:  clamp(2.2rem,  4.4vw, 3.2rem);
    --text-hero: clamp(2.8rem,  5.5vw, 4.8rem);

    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-5:  1.25rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;
    --space-24: 6rem;
    --space-32: 8rem;

    --radius-sm:  12px;
    --radius-md:  20px;
    --radius-lg:  32px;
    --radius-xl:  48px;
    --radius-pill: 100px;

    --ease-out-expo:    cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out-circ: cubic-bezier(0.85, 0, 0.15, 1);

    --max-width: 1240px;
    --gutter:    clamp(1.25rem, 5vw, 4rem);

    --shadow-sm:   0 2px 12px rgba(78, 72, 50, 0.08);
    --shadow-md:   0 6px 28px rgba(78, 72, 50, 0.13);
    --shadow-lg:   0 16px 56px rgba(78, 72, 50, 0.18);
    --shadow-gold: 0 6px 28px rgba(206, 196, 167, 0.30);
  }

  /* ─── Reset ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }
  section[id] {
    scroll-margin-top: 100px;
  }

  body {
    background-color: var(--clr-white);
    background-image: linear-gradient(rgba(252, 250, 246, 0.94), rgba(252, 250, 246, 0.94)), url('/modern-studio-bg.png');
    background-attachment: fixed;
    background-size: cover;
    background-position: center;
    color: var(--clr-text-dark);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 400;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  body.is-loading { overflow: hidden; }

  @media (hover: none) and (pointer: coarse) {
    body { cursor: auto; }
  }

  img, video { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  ul, ol { list-style: none; }
  button { font-family: inherit; border: none; background: none; cursor: pointer; }

  /* ─── Section wrapper ────────────────────────────────────────── */
  section {
    position: relative;
    border-radius: 0 0 64px 64px;
    margin-bottom: -64px;
    padding-top: 64px; /* Space for overlap from previous section */
    padding-bottom: calc(var(--space-32) + 64px) !important;
    background-color: var(--clr-white); /* fallback */
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
  }
  
  /* The very first section shouldn't have top padding from overlap */
  main > section:first-child {
    padding-top: 0;
  }

  @media (max-width: 768px) {
    section {
      border-radius: 0 0 40px 40px;
      margin-bottom: -40px;
      padding-top: 40px;
      padding-bottom: calc(var(--space-16) + 40px) !important;
    }
    main > section:first-child {
      padding-top: 0;
    }
  }

  /* Z-index stacking for sections so previous section overlaps next section */
  main > section:nth-child(1) { z-index: 20; }
  main > section:nth-child(2) { z-index: 19; }
  main > section:nth-child(3) { z-index: 18; }
  main > section:nth-child(4) { z-index: 17; }
  main > section:nth-child(5) { z-index: 16; }
  main > section:nth-child(6) { z-index: 15; }
  main > section:nth-child(7) { z-index: 14; }
  main > section:nth-child(8) { z-index: 13; }
  main > section:nth-child(9) { z-index: 12; }
  main > section:nth-child(10) { z-index: 11; }
  main > section:nth-child(11) { z-index: 10; }
  main > section:nth-child(12) { z-index: 9; }
  main > section:nth-child(13) { z-index: 8; }
  main > section:nth-child(14) { z-index: 7; }
  main > section:nth-child(15) { z-index: 6; }
  main > section:nth-child(16) { z-index: 5; }
  main > section:nth-child(17) { z-index: 4; }
  main > section:nth-child(18) { z-index: 3; }
  main > section:nth-child(19) { z-index: 2; }
  main > section:nth-child(20) { z-index: 1; }

  .section {
    padding: var(--space-32) var(--gutter);
  }
  @media (max-width: 768px) {
    .section {
      padding: var(--space-16) var(--gutter);
    }
  }
  .section--dark {
    background-color: var(--clr-navy) !important;
    color: var(--clr-white);
  }
  .section--light {
    background-color: var(--clr-off-white) !important;
  }

  /* ─── Section label pill ─────────────────────────────────────── */
  .section__label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-gold-dark);
    background: var(--clr-gold-pale);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-4);
    border: 1px solid rgba(206, 196, 167, 0.25);
  }
  .section__label--light {
    background: rgba(206, 196, 167, 0.15);
    border-color: rgba(206, 196, 167, 0.3);
  }

  /* ─── Buttons ───────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      transform 0.25s var(--ease-out-expo),
      box-shadow 0.25s ease,
      background 0.25s ease,
      color 0.2s ease;
    white-space: nowrap;
    will-change: transform;
  }

  .btn--primary {
    background: var(--clr-gold);
    color: var(--clr-navy);
    box-shadow: var(--shadow-gold);
  }
  .btn--primary:hover {
    background: var(--clr-gold-light);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(206, 196, 167, 0.42);
  }

  .btn--navy {
    background: var(--clr-navy);
    color: var(--clr-white);
    box-shadow: var(--shadow-md);
  }
  .btn--navy:hover {
    background: var(--clr-navy-mid);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .btn--outline {
    background: transparent;
    color: var(--clr-white);
    border: 2px solid rgba(255, 255, 255, 0.45);
  }
  .btn--outline:hover {
    border-color: var(--clr-gold);
    color: var(--clr-gold);
    background: rgba(206, 196, 167, 0.08);
  }

  .btn--light {
    background: var(--clr-white);
    color: var(--clr-navy);
    box-shadow: var(--shadow-sm);
  }
  .btn--light:hover {
    background: var(--clr-off-white);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  /* ─── Divider line ───────────────────────────────────────────── */
  .divider {
    width: 52px;
    height: 3px;
    background: linear-gradient(90deg, var(--clr-gold), var(--clr-gold-light));
    border-radius: 99px;
    margin-bottom: var(--space-6);
  }

  /* ─── Global Features ─── */
  .sticky-sidebar {
    position: fixed;
    left: 0;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: left bottom;
    z-index: 1000;
    background: var(--clr-gold);
    color: var(--clr-navy);
    padding: 12px 28px;
    text-decoration: none;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    box-shadow: 4px 0 16px rgba(0,0,0,0.25);
    transition: background 0.3s ease, transform 0.3s ease;
    display: block;
    white-space: nowrap;
  }
  .sticky-sidebar:hover {
    background: var(--clr-gold-dark);
    color: var(--clr-white);
    transform: translateY(-50%) rotate(-90deg) scale(1.03);
  }

  @media (max-width: 1024px) {
    .sticky-sidebar { display: none; }
  }
</style>

<script>
  // Lenis smooth scrolling removed to restore normal scroll speed.

  // Remove 'is-loading' class if Loader is not present
  if (!document.getElementById('loader')) {
    document.body.classList.remove('is-loading');
  }
</script>
