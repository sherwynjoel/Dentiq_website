---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Contact from '../components/Contact.astro';

const placeholders = [
  { id: 1, tag: "Treatment Type" },
  { id: 2, tag: "Treatment Type" },
  { id: 3, tag: "Treatment Type" },
  { id: 4, tag: "Treatment Type" },
  { id: 5, tag: "Treatment Type" },
  { id: 6, tag: "Treatment Type" },
];
---

<BaseLayout
  title="Patient Results & Smile Transformations | DentiQ Superspeciality Erode"
  description="See real before and after results from DentiQ Superspeciality Laser Dental Hospital in Erode."
>
  <Cursor />
  <Nav />

  <main>
    <!-- HERO -->
    <section class="results-hero">
      <div class="results-hero__bg"></div>
      <div class="results-hero__content">
        <span class="section__label section__label--light">Real Patients. Real Results.</span>
        <h1 class="results-hero__heading">Smile Transformations That <em>Speak for Themselves</em></h1>
        <p class="results-hero__sub">
          Every smile in our gallery belongs to a real DentiQ patient — life-changing results our superspecialists deliver every day in Erode.
        </p>
        <div class="results-hero__ctas">
          <a href="#cases" class="btn btn--primary">See the Results</a>
          <a href="#contact" class="btn btn--outline">Book Your Consultation</a>
        </div>
      </div>
    </section>

    <!-- BEFORE / AFTER GALLERY -->
    <section id="cases" class="cases section">
      <div class="container">
        <div class="section-header">
          <span class="section__label">Transformations</span>
          <h2 class="section__heading">Before &amp; After <em>Gallery</em></h2>
          <p class="section-sub">Real results from real patients. Images coming soon.</p>
        </div>

        <div class="cases__grid">
          {placeholders.map((item) => (
            <div class="case-card">
              <div class="case-card__img-box">
                <div class="before-after">
                  <div class="before-after__half">
                    <!-- BEFORE IMAGE: replace src with actual image path -->
                    <div class="img-placeholder">
                      <span>Before</span>
                    </div>
                    <span class="ba-label ba-label--before">Before</span>
                  </div>
                  <div class="before-after__divider"></div>
                  <div class="before-after__half">
                    <!-- AFTER IMAGE: replace src with actual image path -->
                    <div class="img-placeholder">
                      <span>After</span>
                    </div>
                    <span class="ba-label ba-label--after">After</span>
                  </div>
                  <div class="case-card__overlay">
                    <span class="case-card__tag">{item.tag}</span>
                  </div>
                </div>
              </div>
              <div class="case-card__content">
                <div class="case-card__meta">
                  <span class="case-card__category">Category</span>
                  <span class="case-card__duration">Duration</span>
                </div>
                <h3 class="case-card__title">Case Title</h3>
                <p class="case-card__desc">Patient description goes here.</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Contact />
  </main>

  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter); }
  .section-header { text-align: center; margin-bottom: var(--space-16); max-width: 800px; margin-left: auto; margin-right: auto; }
  .section__heading { font-family: var(--font-heading); font-size: var(--text-3xl); margin-bottom: var(--space-6); color: inherit; line-height: 1.1; }
  .section__heading em { font-style: italic; color: var(--clr-gold-dark); }
  .section-sub { font-size: var(--text-lg); opacity: 0.8; font-weight: 300; color: inherit; line-height: 1.6; }

  /* Hero */
  .results-hero {
    position: relative;
    background: linear-gradient(135deg, var(--clr-navy) 0%, #3a4037 100%);
    padding: 14rem var(--gutter) 12rem;
    text-align: center;
  }
  .results-hero__bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(206, 196, 167, 0.1) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .results-hero__content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }
  .results-hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    color: var(--clr-white);
    line-height: 1.1;
  }
  .results-hero__heading em { color: var(--clr-gold); font-style: italic; }
  .results-hero__sub {
    font-size: var(--text-lg);
    font-weight: 300;
    color: rgba(255,255,255,0.8);
    line-height: 1.8;
    max-width: 68ch;
  }
  .results-hero__ctas { display: flex; gap: var(--space-4); flex-wrap: wrap; justify-content: center; }

  /* Cases grid */
  .cases__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .case-card {
    background: var(--clr-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--clr-light-gray);
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s ease, border-color 0.3s ease;
  }
  .case-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--clr-gold);
  }

  .case-card__img-box {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--clr-off-white);
  }

  /* Before/After split */
  .before-after {
    position: absolute;
    inset: 0;
    display: flex;
  }
  .before-after__half {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .before-after__half img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .case-card:hover .before-after__half img {
    transform: scale(1.06);
  }
  .before-after__divider {
    width: 2px;
    background: rgba(255,255,255,0.7);
    z-index: 3;
    flex-shrink: 0;
  }

  /* Image placeholder */
  .img-placeholder {
    width: 100%;
    height: 100%;
    background: var(--clr-off-white);
    border: 2px dashed var(--clr-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .img-placeholder span {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-text-mid);
    opacity: 0.5;
  }

  .ba-label {
    position: absolute;
    top: var(--space-3);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.55);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    white-space: nowrap;
    z-index: 4;
  }

  .case-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(45,53,42,0.45), transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: var(--space-4);
    z-index: 2;
    pointer-events: none;
  }
  .case-card__tag {
    background: var(--clr-gold);
    color: var(--clr-navy);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .case-card__content {
    padding: var(--space-6) var(--space-8) var(--space-8);
  }
  .case-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  .case-card__category {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--clr-gold-dark);
    opacity: 0.5;
  }
  .case-card__duration {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--clr-text-mid);
    background: var(--clr-off-white);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    opacity: 0.5;
  }
  .case-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--clr-navy);
    margin-bottom: var(--space-3);
    opacity: 0.4;
  }
  .case-card__desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--clr-text-mid);
    font-weight: 300;
    opacity: 0.4;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .cases__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cases__grid { grid-template-columns: 1fr; }
    .results-hero__ctas { flex-direction: column; width: 100%; }
    .btn { width: 100%; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.results-hero__content > *', {
    y: 24, opacity: 0, stagger: 0.1, duration: 0.7, ease: 'power2.out'
  });

  gsap.from('.case-card', {
    scrollTrigger: { trigger: '.cases__grid', start: 'top 85%' },
    y: 40, opacity: 0, stagger: 0.1, duration: 0.9, ease: 'power3.out'
  });
</script>
