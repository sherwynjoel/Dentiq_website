---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="About Us | DentiQ Superspeciality Laser Dental Hospital Erode" description="DentiQ is Erode's best dental hospital in Palayapalayam. Our expert superspecialists provide 5-star comfort and world-class sterile dental care.">
  <Cursor />
  <Nav />

  <!-- About Hero -->
  <section class="about-hero">
    <div class="about-hero__bg"></div>
    <div class="about-hero__content">
      <span class="section__label section__label--light" data-flicker>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M2 12h20"/></svg>
        Our Story
      </span>
      <h1 class="about-hero__heading">State-of-the-Art <em>Care in Erode</em></h1>
      <p class="about-hero__sub">
        Discover why DentiQ is the premier destination for comprehensive, comfortable, and affordable superspeciality dentistry.
      </p>
    </div>
  </section>

  <!-- Comprehensive Care (WHITE) -->
  <section class="comprehensive">
    <div class="container">
      <div class="comp-grid">
        <div class="comp-left">
          <span class="section__label">Preventive Focus</span>
          <h2 class="section__heading">Comprehensive <em>Dental & General Health</em></h2>
          <p>
            We believe that preventive care and education are the keys to optimal dental health. We strive to provide “Comprehensive dental health care.” That’s why we focus on thorough exams – checking the overall health of your teeth and gums, performing oral cancer exams, and taking x-rays when necessary.
          </p>
          <p>
            We also emphasize routine cleanings, flossing, sealants, and fluoride application that are helpful in preventing dental disease.
          </p>
        </div>
        <div class="comp-right">
          <div class="health-box">
            <h4>The Health Connection</h4>
            <p>Not only are we focused on the beauty of your smile, we’re also concerned about your health. Countless studies have demonstrated a link between poor oral health and systemic diseases such as:</p>
            <div class="health-grid">
              <div class="health-item"><span>Heart Disease</span></div>
              <div class="health-item"><span>Diabetes</span></div>
              <div class="health-item"><span>Rheumatoid Arthritis</span></div>
              <div class="health-item"><span>Pregnancy Safety</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5-Star Comforts (OFF-WHITE) -->
  <section class="comforts">
    <div class="container">
      <div class="section-header">
        <span class="section__label">Unmatched Experience</span>
        <h2 class="section__heading">5-Star <em>Comforts</em></h2>
        <p class="section-sub">The only dental clinic in Erode designed specifically for your comfort:</p>
      </div>
      <div class="comforts-grid">
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
          </div>
          <h3>Music & Ambience</h3>
          <p>Headphones and soothing background instrumentals to help you relax — many patients even doze off!</p>
        </div>
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2M4.93 19.07l1.41-1.41M12 20v2M17.66 17.66l1.41 1.41M20 12h2M17.66 6.34l1.41-1.41"/></svg>
          </div>
          <h3>Light Sensitivity</h3>
          <p>Premium sunglasses provided to ensure your comfort under procedure lighting.</p>
        </div>
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Anxiety Relief</h3>
          <p>Sleep Eyemasks available for anxious patients to ensure a completely stress-free experience.</p>
        </div>
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"/><path d="M3 20h18"/><path d="M5 14h14v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-4z"/></svg>
          </div>
          <h3>Relaxation Chairs</h3>
          <p>Ultra-comfortable ergonomic chairs in every room to help you relax throughout your visit.</p>
        </div>
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22v-4M8 18h8M12 8v10M12 2v6M20 12h-4M8 12H4M17.66 6.34l-2.83 2.83M9.17 14.83l-2.83 2.83M17.66 17.66l-2.83-2.83M9.17 9.17l-2.83-2.83"/></svg>
          </div>
          <h3>Custom Climate</h3>
          <p>Individual aircon settings in every operatory to keep you perfectly comfy during care.</p>
        </div>
        <div class="comfort-card">
          <div class="comfort-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.71-2.16 0-3a2.12 2.12 0 0 0-3 0Z"/><path d="m8 13 4 4L22 7l-4-4L8 13Z"/><path d="m15 6 4 4"/></svg>
          </div>
          <h3>Orthopedic Care</h3>
          <p>Special head and neck pillows designed specifically for patients with orthopedic needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Care (DARK NAVY) -->
  <section class="our-care section--dark">
    <div class="container">
      <div class="care-grid">
        <div class="care-content">
          <span class="section__label section__label--light">Premier Hospital</span>
          <h2 class="section__heading">Our <em>Care</em></h2>
          <p class="care-text">
            When you visit DentiQ for the first time, you’ll be amazed at our service and ambience. We are the best dental facility in the heart of Erode with state-of-the-art equipment and a superspecialist team.
          </p>
          <p class="care-text">
            Our exceptional team is committed to providing comfortable and gentle dentistry with virtually zero waiting time.
          </p>
          <div class="featured-quote">
            "Get yourself pampered with 5 Star comforts while you are on the way to an everlasting bright happy smile!"
          </div>
        </div>
        <div class="care-visual">
          <img src="/Screenshot%202026-04-29%20221706.png" alt="Dr. Dilip performing dental procedure" class="care-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- Sterile & Updates (WHITE) -->
  <section class="sterile">
    <div class="container">
      <div class="dual-columns">
        <div class="column">
          <span class="section__label">Highly Sterile Practice</span>
          <h2 class="section__heading">You're <em>Safe With Us</em></h2>
          <p>
            Infection control is of paramount importance for us. We are proud to say we are the <strong>only clinic in Erode</strong> to use a world-class <strong>Class B Autoclave</strong> to sterilize our instruments.
          </p>
        </div>
        <div class="column">
          <span class="section__label">Latest Technology</span>
          <h2 class="section__heading">Ever <em>Updating</em></h2>
          <p>
            We pride ourselves in providing the latest treatment options. We constantly update ourselves attending international dental conventions to stay informed of the latest techniques.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final Note (OFF-WHITE) -->
  <section class="final-note">
    <div class="container">
      <div class="final-grid">
        <div class="final-card">
          <h3>A Pleasant Experience</h3>
          <p>Building a foundation of trust by treating our patients as special individuals is vital to our success. Our entire team is dedicated to providing you with excellent, personalized care and service to make your visits as comfortable as possible.</p>
        </div>
        <div class="final-card final-card--gold">
          <h3>Affordable Cost</h3>
          <p>The cost of cosmetic dentistry with us is affordable and we offer effective treatments that fit every pocket. Expert care shouldn't be out of reach.</p>
          <a href="#contact" class="btn btn--light">Book Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter); }
  .section--dark { background: var(--clr-navy) !important; color: var(--clr-white); }
  .section-header { text-align: center; margin-bottom: var(--space-16); max-width: 700px; margin-left: auto; margin-right: auto; }
  .section__heading { font-family: var(--font-heading); font-size: var(--text-3xl); margin-bottom: var(--space-6); color: inherit; line-height: 1.1; }
  .section__heading em { font-style: italic; color: var(--clr-gold); }
  .section-sub { font-size: var(--text-lg); opacity: 0.8; font-weight: 300; color: inherit; }

  /* Section Overlap Logic */
  section {
    position: relative;
    border-radius: 0 0 64px 64px;
    margin-bottom: -64px;
    padding: var(--space-32) 0 calc(var(--space-32) + 64px) !important;
  }
  
  section:nth-child(1) { z-index: 20; }
  section:nth-child(2) { z-index: 19; }
  section:nth-child(3) { z-index: 18; }
  section:nth-child(4) { z-index: 17; }
  section:nth-child(5) { z-index: 16; }
  section:nth-child(6) { z-index: 15; }
  section:nth-child(7) { z-index: 14; }
  section:nth-child(8) { z-index: 13; }

  /* Hero */
  .about-hero {
    background: linear-gradient(135deg, rgba(78, 72, 50, 0.92) 0%, rgba(91, 84, 60, 0.95) 100%), url('/modern-studio-bg.png') center/cover no-repeat;
    padding: 12rem var(--gutter) 10rem !important;
    text-align: center;
    border-radius: 0;
  }
  .about-hero__bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .about-hero__content { position: relative; z-index: 1; max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-5); }
  .about-hero__heading { font-family: var(--font-heading); font-size: var(--text-hero); font-weight: 600; color: var(--clr-white); line-height: 1.05; }
  .about-hero__heading em { font-style: italic; color: var(--clr-gold); }
  .about-hero__sub { font-size: var(--text-lg); font-weight: 300; color: rgba(255,255,255,0.8); line-height: 1.8; max-width: 60ch; }

  /* Comprehensive */
  .comprehensive { background: var(--clr-white); }
  .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: center; }
  .comp-left p { font-size: var(--text-base); line-height: 1.8; margin-bottom: var(--space-5); color: var(--clr-text-body); font-weight: 300; }
  
  .health-box { background: var(--clr-off-white); padding: var(--space-10); border-radius: var(--radius-xl); border: 1px solid var(--clr-light-gray); }
  .health-box h4 { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--clr-navy); margin-bottom: var(--space-4); }
  .health-box p { font-size: var(--text-sm); line-height: 1.7; margin-bottom: var(--space-6); opacity: 0.8; }
  .health-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
  .health-item { background: var(--clr-white); padding: 12px; border-radius: var(--radius-sm); font-size: 0.75rem; font-weight: 700; color: var(--clr-navy); text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid rgba(78,72,50,0.05); }

  /* Comforts */
  .comforts { background: var(--clr-off-white); }
  .comforts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .comfort-card { background: var(--clr-white); padding: var(--space-10) var(--space-8); border-radius: var(--radius-xl); border: 1px solid var(--clr-light-gray); transition: all 0.4s var(--ease-out-expo); display: flex; flex-direction: column; gap: var(--space-4); }
  .comfort-card:hover { transform: translateY(-10px); border-color: var(--clr-gold); box-shadow: var(--shadow-lg); }
  .comfort-icon { width: 52px; height: 52px; background: var(--clr-gold-pale); color: var(--clr-gold-dark); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background 0.3s ease; }
  .comfort-card:hover .comfort-icon { background: var(--clr-gold); color: var(--clr-navy); }
  .comfort-card h3 { font-family: var(--font-heading); font-size: var(--text-lg); color: var(--clr-navy); font-weight: 600; }
  .comfort-card p { font-size: var(--text-sm); line-height: 1.7; color: var(--clr-text-mid); font-weight: 300; }

  /* Our Care */
  .our-care { background: var(--clr-navy); }
  .care-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-16); align-items: center; }
  .care-text { font-size: var(--text-base); line-height: 1.8; margin-bottom: var(--space-6); color: rgba(255,255,255,0.8); font-weight: 300; }
  .featured-quote { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--clr-gold); font-style: italic; padding-left: var(--space-8); border-left: 4px solid var(--clr-gold); margin-top: var(--space-8); line-height: 1.4; }
  .care-img { width: 100%; height: auto; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); border: 1px solid rgba(255,255,255,0.1); }

  /* Sterile */
  .sterile { background: var(--clr-white); }
  .dual-columns { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); }
  .column p { font-size: var(--text-base); line-height: 1.8; margin-top: var(--space-6); color: var(--clr-text-body); font-weight: 300; }
  .column strong { color: var(--clr-navy); font-weight: 700; }

  /* Final Note */
  .final-note { background: var(--clr-off-white); }
  .final-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-6); }
  .final-card { background: var(--clr-white); padding: var(--space-12) var(--space-10); border-radius: var(--radius-xl); border: 1px solid var(--clr-light-gray); }
  .final-card h3 { font-family: var(--font-heading); font-size: var(--text-2xl); color: var(--clr-navy); margin-bottom: var(--space-5); }
  .final-card p { font-size: var(--text-base); line-height: 1.8; color: var(--clr-text-body); font-weight: 300; }
  .final-card--gold { background: var(--clr-gold); color: var(--clr-white); border: none; }
  .final-card--gold h3 { color: var(--clr-white); }
  .final-card--gold p { color: rgba(255,255,255,0.9); margin-bottom: var(--space-6); }

  @media (max-width: 1024px) {
    .comforts-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 900px) {
    .care-grid, .comp-grid, .dual-columns, .final-grid { grid-template-columns: 1fr; gap: var(--space-12); }
    .about-hero { padding: 10rem var(--gutter) 8rem !important; }
    .about-hero__heading { font-size: 2.5rem; }
  }
  @media (max-width: 600px) {
    .comforts-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about-hero__content > *', { y: 15, opacity: 0, stagger: 0.08, duration: 0.4, ease: 'power2.out' });
  gsap.from('.comp-grid, .comfort-card, .care-grid, .column, .final-card', {
    scrollTrigger: { trigger: '.comprehensive', start: 'top 90%' },
    y: 30, opacity: 0, stagger: 0.1, duration: 0.8, ease: 'power2.out'
  });
</script>
