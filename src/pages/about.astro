<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance
  gsap.from('.about-hero__content > *', { y: 20, opacity: 0, stagger: 0.1, duration: 0.6, ease: 'power2.out' });

  // Scroll animations
  const fadeUp = (selector) => {
    gsap.from(selector, {
      scrollTrigger: { trigger: selector, start: 'top 90%', once: true },
      y: 30, opacity: 0, duration: 0.8, ease: 'power2.out'
    });
  };

  fadeUp('.story__content');
  fadeUp('.stat-card');
  fadeUp('.phi-card');
  fadeUp('.tech-card');
  fadeUp('.comfort-card-new');
  fadeUp('.doctor-card');
  fadeUp('.why-card');
  fadeUp('.accred-content');
  fadeUp('.closing__card');
</script>
