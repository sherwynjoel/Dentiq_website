---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="About Us | DentiQ Superspeciality Laser Dental Hospital Erode" description="DentiQ is Erode's best dental hospital in Palayapalayam. Our expert superspecialists provide 5-star comfort and world-class sterile dental care.">
  <Cursor />
  <Nav />

  <!-- About Hero -->
  <section class="about-hero">
    <div class="about-hero__bg"></div>
    <div class="about-hero__content">
      <span class="section__label section__label--light">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M2 12h20"/></svg>
        Our Story
      </span>
      <h1 class="about-hero__heading">State-of-the-Art <em>Care in Erode</em></h1>
      <p class="about-hero__sub">
        Discover why DentiQ is the premier destination for comprehensive, comfortable, and affordable superspeciality dentistry.
      </p>
    </div>
  </section>

  <!-- Our Care -->
  <section class="our-care">
    <div class="container">
      <div class="care-grid">
        <div class="care-content">
          <span class="section__label">Welcome to DentiQ</span>
          <h2 class="section__heading">Our <em>Care</em></h2>
          <p class="care-text">
            When you visit DentiQ for the first time, you’ll be amazed at our service and ambience. We are the best dental facility in the heart of Erode with state-of-the-art equipment and superspecialist team of Doctors. 
          </p>
          <p class="care-text">
            Our patients are consulted right away and sometimes in virtually very very less waiting time. Our exceptional team is committed to providing comfortable and gentle dentistry.
          </p>
          <div class="featured-quote">
            "Get yourself pampered with 5 Star comforts while you are on the way to an everlasting bright happy smile!"
          </div>
        </div>
        <div class="care-visual">
          <img src="/2B3A7857.JPG" alt="Fellowship Award Ceremony" class="care-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- 5-Star Comforts -->
  <section class="comforts section--dark">
    <div class="container">
      <div class="section-header">
        <span class="section__label section__label--light">Unmatched Experience</span>
        <h2 class="section__heading">5-Star <em>Comforts</em></h2>
        <p class="section-sub">We are the only dental clinic in Erode to treat at your comfort provided with:</p>
      </div>
      <div class="comforts-grid">
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
          </div>
          <h3>Music & Ambience</h3>
          <p>Headphones and in-room soothing background instrumentals to help you relax — many patients even doze off!</p>
        </div>
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H4.5a2.5 2.5 0 1 1 1.8-4.3"/><path d="M9.6 19a2.4 2.4 0 1 1-3 3.6 2.4 2.4 0 0 1-3-3.6 2.4 2.4 0 0 1 3-3.6 2.4 2.4 0 0 1 3 3.6Z"/><path d="M20.4 19a2.4 2.4 0 1 1-3 3.6 2.4 2.4 0 0 1-3-3.6 2.4 2.4 0 0 1 3-3.6 2.4 2.4 0 0 1 3 3.6Z"/></svg>
          </div>
          <h3>Light Sensitivity</h3>
          <p>Premium sunglasses provided for patients with light sensitivity during procedures.</p>
        </div>
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Anxiety Relief</h3>
          <p>Sleep Eyemasks available for anxious patients to ensure a stress-free experience.</p>
        </div>
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>Orthopedic Support</h3>
          <p>Head Pillows and neck supports specially designed for people with orthopedic problems.</p>
        </div>
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07"/></svg>
          </div>
          <h3>Custom Climate</h3>
          <p>Customized aircon settings in every room to keep you perfectly comfy.</p>
        </div>
        <div class="comfort-item">
          <div class="comfort-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 14V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"/><path d="M3 20h18"/><path d="M5 14h14v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-4z"/></svg>
          </div>
          <h3>Relaxation Chairs</h3>
          <p>Ultra-comfortable ergonomic chairs in every room to help you relax at your appointment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comprehensive Care -->
  <section class="comprehensive">
    <div class="container">
      <div class="comp-grid">
        <div class="comp-left">
          <h2 class="section__heading">Comprehensive <em>Dental & General Health</em></h2>
          <p>
            We believe that preventive care and education are the keys to optimal dental health. We strive to provide “Comprehensive dental health care.” That’s why we focus on thorough exams – checking the overall health of your teeth and gums, performing oral cancer exams, and taking x-rays when necessary.
          </p>
          <p>
            We also emphasize routine cleanings, flossing, sealants, and fluoride application that are helpful in preventing dental disease.
          </p>
        </div>
        <div class="comp-right">
          <div class="health-box">
            <h4>The Health Connection</h4>
            <p>Not only are we focused on the beauty of your smile, we’re also concerned about your health. Countless studies have demonstrated a link between poor oral health and systemic diseases such as:</p>
            <ul>
              <li>Heart Disease & Stroke</li>
              <li>Diabetes & Dementia</li>
              <li>Rheumatoid Arthritis</li>
              <li>Skin Diseases</li>
              <li>Pregnancy Complications</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sterile & Updates -->
  <section class="sterile section--dark">
    <div class="container">
      <div class="dual-columns">
        <div class="column">
          <span class="section__label section__label--light">Highly Sterile Practice</span>
          <h2 class="section__heading">You're <em>Safe With Us</em></h2>
          <p>
            Infection control is of paramount importance for us. We are proud to say we are the <strong>only clinic in the whole of Erode</strong> to use world-class <strong>Class B Autoclave</strong> to sterilize our instruments.
          </p>
          <p>
            To protect our patients and ourselves, we strictly maintain sterilization and cross-contamination prevention protocols as recommended by the ADA, OSHA, and the CDC.
          </p>
        </div>
        <div class="column">
          <span class="section__label section__label--light">Latest Technology</span>
          <h2 class="section__heading">Ever <em>Updating</em></h2>
          <p>
            We pride ourselves in providing the latest treatment options. We constantly update ourselves attending international dental conventions, lectures, and meetings to stay informed of latest techniques and products.
          </p>
          <p>
            Being members of various professional dental associations helps us stay abreast of the latest recommendations for state-of-the-art dental care.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience & Cost -->
  <section class="final-note">
    <div class="container">
      <div class="final-grid">
        <div class="final-card">
          <h3>A Pleasant Experience</h3>
          <p>Building a foundation of trust by treating our patients as special individuals is vital to our success. Our entire team is dedicated to providing you with excellent, personalized care and service to make your visits as comfortable and pleasant as possible.</p>
        </div>
        <div class="final-card final-card--gold">
          <h3>Affordable Cost</h3>
          <p>The cost of cosmetic dentistry with us is affordable and we offer the most effective treatments that will fit every pocket. Expert care shouldn't be out of reach.</p>
          <a href="#contact" class="btn btn--light">Call for Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter); }
  .section--dark { background: var(--clr-white); color: var(--clr-text-dark); }
  .section-header { text-align: center; margin-bottom: var(--space-16); }
  .section__heading { font-family: var(--font-heading); font-size: var(--text-3xl); margin-bottom: var(--space-6); color: inherit; }
  .section__heading em { font-style: italic; color: var(--clr-gold); }
  .section-sub { font-size: var(--text-lg); opacity: 0.8; font-weight: 300; color: var(--clr-text-mid); }

  /* Hero */
  .about-hero {
    position: relative;
    background: linear-gradient(135deg, rgba(78, 72, 50, 0.85) 0%, rgba(91, 84, 60, 0.9) 100%), url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1600') center/cover no-repeat;
    padding: 10rem var(--gutter) 6rem;
    overflow: hidden;
    text-align: center;
  }
  .about-hero__bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .about-hero__content { position: relative; z-index: 1; max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: var(--space-5); }
  .about-hero__heading { font-family: var(--font-heading); font-size: var(--text-hero); font-weight: 600; color: var(--clr-white); line-height: 1.1; }
  .about-hero__heading em { font-style: italic; color: var(--clr-gold); }
  .about-hero__sub { font-size: var(--text-lg); font-weight: 300; color: rgba(255,255,255,0.72); line-height: 1.8; }

  /* Our Care */
  .our-care { padding: var(--space-32) 0; background: var(--clr-off-white); }
  .care-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-16); align-items: center; }
  .care-text { font-size: var(--text-base); line-height: 1.8; margin-bottom: var(--space-6); color: var(--clr-text-body); font-weight: 300; }
  .featured-quote { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--clr-navy); font-style: italic; padding-left: var(--space-8); border-left: 4px solid var(--clr-gold); margin-top: var(--space-8); line-height: 1.4; }
  .care-visual {
    position: relative;
    width: 100%;
  }
  .care-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  /* Comforts */
  .comforts { padding: var(--space-32) 0; background: var(--clr-white); }
  .comforts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .comfort-item { background: var(--clr-off-white); padding: var(--space-8); border-radius: var(--radius-lg); border: 1px solid var(--clr-light-gray); transition: transform 0.3s ease; }
  .comfort-item:hover { transform: translateY(-5px); border-color: var(--clr-gold); background: var(--clr-white); box-shadow: var(--shadow-md); }
  .comfort-icon { font-size: 2.5rem; margin-bottom: var(--space-5); color: var(--clr-gold); }
  .comfort-item h3 { font-family: var(--font-heading); font-size: var(--text-xl); margin-bottom: var(--space-3); color: var(--clr-navy); }
  .comfort-item p { font-size: var(--text-sm); line-height: 1.7; color: var(--clr-text-mid); }

  /* Comprehensive */
  .comprehensive { padding: var(--space-32) 0; background: var(--clr-off-white); }
  .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); align-items: center; }
  .comp-left p { font-size: var(--text-base); line-height: 1.8; margin-bottom: var(--space-5); color: var(--clr-text-body); font-weight: 300; }
  .health-box { background: var(--clr-white); padding: var(--space-10); border-radius: var(--radius-xl); border: 1px solid var(--clr-light-gray); }
  .health-box h4 { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--clr-navy); margin-bottom: var(--space-4); }
  .health-box p { font-size: var(--text-sm); line-height: 1.7; margin-bottom: var(--space-5); }
  .health-box ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2); }
  .health-box li { font-size: var(--text-sm); font-weight: 600; color: var(--clr-gold); }
  .health-box li::before { content: '✦'; margin-right: 8px; }

  /* Sterile */
  .sterile { padding: var(--space-32) 0; background: var(--clr-white); }
  .dual-columns { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); }
  .column p { font-size: var(--text-base); line-height: 1.8; margin-top: var(--space-6); color: var(--clr-text-body); font-weight: 300; }
  .column strong { color: var(--clr-gold); }

  /* Final Note */
  .final-note { padding: var(--space-32) 0; background: var(--clr-off-white); }
  .final-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-6); }
  .final-card { background: var(--clr-white); padding: var(--space-10); border-radius: var(--radius-xl); border: 1px solid var(--clr-light-gray); }
  .final-card h3 { font-family: var(--font-heading); font-size: var(--text-2xl); color: var(--clr-navy); margin-bottom: var(--space-5); }
  .final-card p { font-size: var(--text-base); line-height: 1.8; color: var(--clr-text-body); font-weight: 300; }
  .final-card--gold { background: var(--clr-gold); color: var(--clr-white); display: flex; flex-direction: column; gap: var(--space-6); border: none; }
  .final-card--gold h3 { color: var(--clr-white); }
  .final-card--gold p { color: rgba(255,255,255,0.9); }

  @media (max-width: 900px) {
    .care-grid, .comp-grid, .comforts-grid, .dual-columns, .final-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about-hero__content > *', { y: 40, opacity: 0, stagger: 0.12, duration: 1, ease: 'power3.out', delay: 0.2 });
  gsap.from('.care-content > *, .comfort-item, .health-box, .column', {
    scrollTrigger: { trigger: '.our-care', start: 'top 85%' },
    y: 50, opacity: 0, stagger: 0.1, duration: 1, ease: 'power3.out'
  });
</script>
