---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import { treatmentsData } from '../data/treatmentsData.js';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Treatments & Specialities | DentiQ Erode" description="Explore our dental specialities at DentiQ Erode. Find dedicated care for your smile.">
  <Cursor />
  <Nav />

  <section class="treatments-hero">
    <div class="container">
      <span class="section__label section__label--light">Comprehensive Care</span>
      <h1 class="hero__heading">Our <em>Specialities</em></h1>
      <p class="hero__sub">Advanced dental treatments powered by Erode's expert team.</p>
    </div>
  </section>

  <section class="treatments-directory">
    <div class="container">
      <div class="t-search-container">
        <input type="text" id="t-search" placeholder="Search treatments..." class="t-search-input" />
      </div>

      <div class="t-rows" id="t-rows">
        {treatmentsData.map((cat) => (
          <div class="t-row" data-name={cat.name.toLowerCase()}>
            <div class="t-row__content">
              <div class="t-row__icon" set:html={cat.icon}></div>
              <h2 class="t-row__title">{cat.name}</h2>
              {cat.catchy && <p class="t-row__catchy">{cat.catchy}</p>}
              <p class="t-row__desc">{cat.desc}</p>
              <a href={`/treatments/${cat.id}`} class="t-row__link btn btn--primary">View Details</a>
            </div>
            <div class="t-row__image-container">
              <img src={cat.image} alt={cat.name} class="t-row__image" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter); }

  .treatments-hero {
    position: relative;
    background: linear-gradient(135deg, rgba(78, 72, 50, 0.85) 0%, rgba(91, 84, 60, 0.9) 100%), url('https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=1600') center/cover no-repeat;
    padding: 10rem 0 6rem;
    text-align: center;
    color: var(--clr-white);
  }
  .hero__heading { font-family: var(--font-heading); font-size: 3.5rem; margin-bottom: 1.5rem; }
  .hero__heading em { font-style: italic; color: var(--clr-gold); }
  .hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); font-weight: 300; }

  .treatments-directory {
    padding: 6rem 0;
    background: var(--clr-white);
  }

  .t-search-container {
    max-width: 600px;
    margin: 0 auto 5rem;
  }
  .t-search-input {
    width: 100%;
    padding: 16px 24px;
    border-radius: var(--radius-pill);
    border: 2px solid var(--clr-light-gray);
    background: var(--clr-off-white);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--clr-text-dark);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-align: center;
  }
  .t-search-input:focus {
    border-color: var(--clr-navy);
    box-shadow: 0 0 0 4px rgba(78, 72, 50, 0.1);
    background: var(--clr-white);
  }

  .t-rows {
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  .t-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .t-row:nth-child(even) {
    grid-template-columns: 1fr 1fr;
    direction: rtl;
  }
  .t-row:nth-child(even) .t-row__content {
    direction: ltr;
  }

  @media (max-width: 900px) {
    .t-row, .t-row:nth-child(even) {
      grid-template-columns: 1fr;
      gap: 2rem;
      direction: ltr;
    }
  }

  .t-row__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .t-row__icon {
    width: 56px;
    height: 56px;
    background: var(--clr-gold-pale);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-navy);
    margin-bottom: 1.5rem;
  }
  
  .t-row__title { font-family: var(--font-heading); font-size: 2rem; color: var(--clr-navy); margin-bottom: 1rem; }
  .t-row__catchy { font-size: var(--text-base); color: var(--clr-gold); font-weight: 500; margin-bottom: 1.5rem; line-height: 1.4; }
  .t-row__desc { font-size: var(--text-sm); color: var(--clr-text-body); line-height: 1.8; margin-bottom: 2rem; font-weight: 300; }

  .t-row__image-container {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .t-row__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .t-row:hover .t-row__image {
    transform: scale(1.05);
  }

  .t-row__link {
    padding: 12px 32px;
    font-size: 0.9rem;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-weight: 600;
  }
</style>

<script>
  const searchInput = document.getElementById('t-search') as HTMLInputElement;
  const rows = document.querySelectorAll('.t-row') as NodeListOf<HTMLElement>;

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    rows.forEach(row => {
      const name = row.dataset.name || '';
      if (name.includes(query)) {
        row.style.display = 'grid';
      } else {
        row.style.display = 'none';
      }
    });
  });
</script>
