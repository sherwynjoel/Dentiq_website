---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Contact from '../components/Contact.astro';

const posts = [
  {
    title: 'TMJ Specialist Guide: Finding Certified Care in India',
    category: 'Expert Guide',
    date: 'April 20, 2024',
    excerpt: 'A deep dive into finding board-certified TMJ specialists in India for effective TMD management and long-term relief.',
    imageIcon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C8 2 4 5.5 4 9c0 2.5 1.5 4.5 3 6l1 5h8l1-5c1.5-1.5 3-3.5 3-6 0-3.5-4-7-8-7z"/><path d="M9 9h6M12 6v6"/></svg>`,
    link: '#'
  },
  {
    title: '10 Best Jaw Exercises for Chronic Pain Relief',
    category: 'Patient Care',
    date: 'April 05, 2024',
    excerpt: 'A comprehensive manual on targeted stretches to alleviate jaw tension and improve TMJ function effectively at home.',
    imageIcon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>`,
    link: '#'
  },
  {
    title: 'Orofacial Pain Relief Options in Bangalore',
    category: 'Regional Updates',
    date: 'March 15, 2024',
    excerpt: 'Exploring the latest specialized orofacial and migraine relief options available for patients in the Bangalore region.',
    imageIcon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>`,
    link: '#'
  }
];
---

<BaseLayout title="Dental Health Blog | Dentiq — Expert Dental Advice" description="Read the latest articles on dental health, TMJ treatment, sleep dentistry, and cosmetic procedures from the experts at Dentiq.">
  <Cursor />
  <Nav />

  <!-- Blog Hero -->
  <section class="blog-hero">
    <div class="blog-hero__bg"></div>
    <div class="blog-hero__content">
      <span class="section__label section__label--light">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M2 12h20"/></svg>
        Dentiq Insights
      </span>
      <h1 class="blog-hero__heading">Dental Health <em>Insights</em></h1>
      <p class="blog-hero__sub">
        Expert advice, patient stories, and the latest advancements in dental and orofacial pain treatment.
      </p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="blog-list">
    <div class="blog-list__inner">
      <div class="blog-grid">
        {posts.map((post, i) => (
          <article class="blog-card" data-index={i}>
            <div class="blog-card__header">
              <div class="blog-card__img-placeholder">
                <span class="blog-card__icon" set:html={post.imageIcon}></span>
              </div>
              <div class="blog-card__tag">{post.category}</div>
            </div>
            <div class="blog-card__body">
              <span class="blog-card__date">{post.date}</span>
              <h2 class="blog-card__title">
                <a href={post.link}>{post.title}</a>
              </h2>
              <p class="blog-card__excerpt">{post.excerpt}</p>
              <a href={post.link} class="blog-card__read-more">
                Read Article
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination Placeholder -->
      <div class="blog-pagination">
        <button class="blog-pagination__btn blog-pagination__btn--active">1</button>
        <button class="blog-pagination__btn">2</button>
        <button class="blog-pagination__btn">3</button>
        <span class="blog-pagination__dots">...</span>
        <button class="blog-pagination__btn">12</button>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="newsletter">
    <div class="newsletter__inner">
      <div class="newsletter__content">
        <h2 class="newsletter__heading">Stay Informed</h2>
        <p class="newsletter__sub">Subscribe to our newsletter for the latest dental tips and clinic updates.</p>
      </div>
      <form class="newsletter__form">
        <input type="email" placeholder="Your email address" required />
        <button type="submit" class="btn btn--primary">Subscribe</button>
      </form>
    </div>
  </section>

  <Contact />
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .blog-hero {
    position: relative;
    background: linear-gradient(135deg, rgba(78, 72, 50, 0.85) 0%, rgba(91, 84, 60, 0.9) 100%), url('https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&q=80&w=1600') center/cover no-repeat;
    padding: 10rem var(--gutter) 6rem;
    overflow: hidden;
    text-align: center;
  }
  .blog-hero__bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }
  .blog-hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }
  .blog-hero__heading {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    font-weight: 600;
    color: var(--clr-white);
    line-height: 1.1;
  }
  .blog-hero__heading em { font-style: italic; color: var(--clr-gold); }
  .blog-hero__sub {
    font-size: var(--text-lg);
    font-weight: 300;
    color: rgba(255,255,255,0.72);
    line-height: 1.8;
    max-width: 56ch;
  }

  /* ── Blog Grid ── */
  .blog-list {
    background: var(--clr-off-white);
    padding: var(--space-32) var(--gutter);
  }
  .blog-list__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-16);
  }

  .blog-card {
    background: var(--clr-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--clr-light-gray);
    display: flex;
    flex-direction: column;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s ease;
  }
  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .blog-card__header {
    position: relative;
    height: 220px;
    background: var(--clr-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .blog-card__img-placeholder {
    width: 80px;
    height: 80px;
    background: rgba(206, 196, 167, 0.15);
    border: 1px solid rgba(206, 196, 167, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-gold);
    font-size: 2.5rem;
    position: relative;
    z-index: 1;
  }
  .blog-card__header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(206, 196, 167, 0.1) 0%, transparent 70%);
  }
  .blog-card__tag {
    position: absolute;
    top: var(--space-5);
    left: var(--space-5);
    background: var(--clr-gold);
    color: var(--clr-white);
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
  }

  .blog-card__body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .blog-card__date {
    font-size: 0.75rem;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .blog-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.3;
    margin-bottom: var(--space-4);
  }
  .blog-card__title a {
    color: inherit;
    transition: color 0.3s ease;
  }
  .blog-card__title a:hover {
    color: var(--clr-gold);
  }
  .blog-card__excerpt {
    font-size: var(--text-sm);
    color: var(--clr-text-body);
    line-height: 1.7;
    margin-bottom: var(--space-6);
    flex: 1;
  }

  .blog-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--clr-gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: gap 0.3s ease;
  }
  .blog-card__read-more:hover {
    gap: var(--space-4);
  }

  /* ── Pagination ── */
  .blog-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
  }
  .blog-pagination__btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--clr-light-gray);
    background: var(--clr-white);
    color: var(--clr-navy);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .blog-pagination__btn--active,
  .blog-pagination__btn:hover {
    background: var(--clr-gold);
    border-color: var(--clr-gold);
    color: var(--clr-white);
  }
  .blog-pagination__dots {
    color: var(--clr-text-mid);
    font-weight: 600;
  }

  /* ── Newsletter ── */
  .newsletter {
    background: var(--clr-navy);
    padding: var(--space-20) var(--gutter);
  }
  .newsletter__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-10);
  }
  .newsletter__content {
    flex: 1;
  }
  .newsletter__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--clr-white);
    margin-bottom: var(--space-2);
  }
  .newsletter__sub {
    color: rgba(255,255,255,0.7);
    font-size: var(--text-base);
  }
  .newsletter__form {
    display: flex;
    gap: var(--space-4);
    min-width: 400px;
  }
  .newsletter__form input {
    flex: 1;
    padding: 12px 20px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.05);
    color: var(--clr-white);
    outline: none;
  }
  .newsletter__form input:focus {
    border-color: var(--clr-gold);
  }
  .newsletter__form button {
    white-space: nowrap;
  }

  @media (max-width: 960px) {
    .newsletter__inner {
      flex-direction: column;
      text-align: center;
    }
    .newsletter__form {
      min-width: 100%;
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .newsletter__form {
      flex-direction: column;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.blog-hero__content > *', {
    y: 40, opacity: 0, stagger: 0.12, duration: 1, ease: 'power3.out', delay: 0.2,
  });

  gsap.from('.blog-card', {
    scrollTrigger: {
      trigger: '.blog-grid',
      start: 'top 85%'
    },
    y: 50,
    opacity: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power3.out'
  });
</script>
