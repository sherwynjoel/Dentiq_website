---
---

<footer id="footer" role="contentinfo">
  <div class="footer__info-cards">
    <div class="info-card-wrap">
      <div class="info-card">
        <div class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="info-card__content">
          <p class="info-card__label">Call Us Today</p>
          <a href="tel:+918489488999" class="info-card__link">+91 84894 88999</a>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="info-card__content">
          <p class="info-card__label">Email Us</p>
          <a href="mailto:info@dentiqsuperspeciality.com" class="info-card__link">info@dentiqsuperspeciality.com</a>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="info-card__content">
          <p class="info-card__label">Our Location</p>
          <span class="info-card__val">Palayapalayam, Erode</span>
        </div>
      </div>
      <div class="info-card info-card--featured">
        <div class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <div class="info-card__content">
          <p class="info-card__label">Live Chat</p>
          <span class="info-card__val">Chat on WhatsApp</span>
        </div>
      </div>
    </div>
  </div>
  <div class="footer__inner">
    <div class="footer__top">

      <!-- Brand column -->
      <div class="footer__brand">
        <div class="footer__logo-img-wrap" style="margin-bottom: 2rem;">
          <img src="/logo.png" alt="DentiQ Logo" style="height: 50px; width: auto; display: block;" />
        </div>
        <p class="footer__desc">
          Erode's premier dental facility providing comprehensive dentistry, 
          advanced restorative care, and 5-star patient comfort in the heart of Palayapalayam.
        </p>
        <div class="footer__socials">
          <a href="https://www.instagram.com/dentiqerode/" target="_blank" rel="noopener noreferrer" class="footer__social" data-cursor-hover aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://www.facebook.com/DentiQErode/" target="_blank" rel="noopener noreferrer" class="footer__social" data-cursor-hover aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.youtube.com/@DentiQHospital" target="_blank" rel="noopener noreferrer" class="footer__social" data-cursor-hover aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <nav class="footer__nav" aria-label="Footer navigation">
        <h4 class="footer__nav-heading">Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/treatments">Treatments</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>

      <!-- Services links -->
      <nav class="footer__nav" aria-label="Services navigation">
        <h4 class="footer__nav-heading">Our Services</h4>
        <ul>
          <li><a href="/treatments#tmj">TMJ Treatment</a></li>
          <li><a href="/treatments#sleep">Sleep Dentistry</a></li>
          <li><a href="/treatments#migraine">Migraine Treatment</a></li>
          <li><a href="/treatments#implants">Specialised Implants</a></li>
          <li><a href="/treatments#invisalign">Invisalign</a></li>
          <li><a href="/treatments#smile">Smile Designing</a></li>
        </ul>
      </nav>

      <!-- Doctors list column -->
      <div class="footer__nav footer__doctors">
        <h4 class="footer__nav-heading">Our Expert Doctors</h4>
        <div class="footer__doctors-grid">
          <ul>
            <li>Dr. Jane Smith, MDS</li>
            <li>Dr. Bala Murugan, MDS</li>
            <li>Dr. Robert Johnson, MDS</li>
          </ul>
          <ul>
            <li>Dr. Emily Davis</li>
            <li>Dr. Michael Brown</li>
            <li>Dr. Sarah Wilson</li>
          </ul>
        </div>
      </div>

      <!-- Contact info -->
      <div class="footer__contact">
        <h4 class="footer__nav-heading">Visit Us</h4>
        <p>
          <strong>Palayapalayam</strong><br />
          Near Perundurai Road,<br />
          Erode, Tamilnadu
        </p>
        <div class="footer__branches-mini">
           <p><strong>Primary Hospital:</strong> Erode</p>
        </div>
      </div>

    </div>

    <div class="footer__bottom">
      <p>&copy; 2025 DentiQ Superspeciality. All rights reserved.</p>
      <p class="footer__cities">Palayapalayam, Erode, Tamilnadu</p>
    </div>
  </div>
</footer>

<style>
  #footer {
    background: var(--clr-white);
    color: var(--clr-navy);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: var(--space-16);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--gutter) var(--space-8);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1.1fr 1.8fr 1.1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }

  /* Info Cards Row */
  .footer__info-cards {
    background: var(--clr-off-white);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    padding: var(--space-10) var(--gutter);
  }
  .info-card-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1024px) {
    .info-card-wrap { grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
  }
  @media (max-width: 600px) {
    .info-card-wrap { grid-template-columns: 1fr; gap: var(--space-6); }
  }
  .info-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .info-card__icon {
    width: 44px;
    height: 44px;
    background: var(--clr-gold-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: var(--clr-gold-dark);
  }
  .info-card__label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-gold-dark);
    margin-bottom: 3px;
  }
  .info-card__link, .info-card__val {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--clr-navy);
    text-decoration: none;
  }
  .info-card--featured .info-card__icon {
    background: var(--clr-gold-dark);
    color: var(--clr-white);
  }

  /* Doctors List */
  .footer__doctors-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .footer__doctors-grid ul li {
    font-size: 0.75rem;
    color: var(--clr-navy);
    opacity: 0.7;
    margin-bottom: 6px;
    font-weight: 300;
  }
  .footer__branches-mini {
    margin-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer__branches-mini p { font-size: 0.7rem !important; }

  /* Brand */
  .footer__logo-img-wrap img {
    /* filter: brightness(0) invert(1); */
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.1;
    margin-bottom: var(--space-1);
  }

  .footer__tagline {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clr-gold-dark);
    margin-bottom: var(--space-5);
  }

  .footer__desc {
    font-size: var(--text-xs);
    font-weight: 300;
    line-height: 1.9;
    color: var(--clr-text-body);
    max-width: 30ch;
    margin-bottom: var(--space-6);
  }

  .footer__socials {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social {
    width: 36px;
    height: 36px;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-navy);
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }
  .footer__social svg { width: 15px; height: 15px; }
  .footer__social:hover {
    background: var(--clr-gold-dark);
    color: var(--clr-white);
    border-color: var(--clr-gold-dark);
  }

  /* Navigation columns */
  .footer__nav-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-navy);
    margin-bottom: var(--space-5);
  }

  .footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav a {
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-text-body);
    transition: all 0.2s ease;
    position: relative;
  }
  .footer__nav a:hover { color: var(--clr-gold-dark); }

  /* Contact column */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .footer__contact p {
    font-size: var(--text-xs);
    font-weight: 300;
    line-height: 1.85;
    color: var(--clr-text-body);
  }
  .footer__contact strong { color: var(--clr-gold-dark); font-weight: 600; }

  .footer__phone,
  .footer__email {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--clr-navy);
    transition: color 0.2s ease;
  }
  .footer__phone:hover,
  .footer__email:hover { color: var(--clr-gold-dark); }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-text-mid);
    letter-spacing: 0.04em;
  }

  .footer__cities {
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .footer__top { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 580px) {
    .footer__top { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; text-align: center; }
  }
</style>
