---
---

<section id="locations" class="section locations">
  <div class="locations__inner">
    <div class="locations__header">
      <span class="section__label">Visit Us</span>
      <h2 class="locations__heading">Our <em>Hospital</em></h2>
      <p class="locations__sub">
        Serving the needs of your entire family in the heart of Palayapalayam.
      </p>
    </div>

    <div class="locations__grid locations__grid--center">
      <article class="location-card location-card--featured">
        <div class="location-card__head">
          <div class="location-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <span class="location-card__city">Erode Headquarter</span>
            <span class="location-card__badge location-card__badge--open">Superspeciality Hospital</span>
          </div>
        </div>
        <div class="location-card__divider"></div>
        <h4 class="location-card__branch">DentiQ Laser Dental Hospital</h4>
        <address class="location-card__address">
          Palayapalayam, Near Perundurai Road,<br />
          Erode, Tamilnadu — 638011<br />
          India
        </address>
        <div class="location-card__services">
          <span>Laser Dentistry</span>
          <span>Cosmetic Dental</span>
          <span>Implant Surgery</span>
          <span>Pediatric Care</span>
        </div>
        <div class="location-card__hours">
          <span>Mon–Sat: 9:00 AM – 8:00 PM</span>
          <span>Sunday: 10:00 AM – 8:00 PM</span>
        </div>
        <a href="tel:+918489488999" class="btn btn--primary location-card__btn" data-cursor-hover>
          Call: +91 84894 88999
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .locations {
    padding: var(--space-32) var(--gutter);
    background: var(--clr-off-white);
  }
  .locations__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .locations__header {
    text-align: center;
    margin-bottom: var(--space-16);
  }
  .locations__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--clr-navy);
    margin-top: var(--space-4);
  }
  .locations__heading em { font-style: italic; color: var(--clr-gold-dark); }
  .locations__sub { font-size: var(--text-base); color: var(--clr-text-mid); font-weight: 300; }

  .locations__grid--center {
    display: flex;
    justify-content: center;
  }

  .location-card {
    max-width: 500px;
    width: 100%;
    background: var(--clr-white);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    border: 1px solid var(--clr-light-gray);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  
  .location-card__head { display: flex; align-items: center; gap: var(--space-4); }
  .location-card__icon { width: 48px; height: 48px; background: var(--clr-gold-pale); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--clr-gold-dark); }
  .location-card__city { display: block; font-family: var(--font-heading); font-size: var(--text-xl); color: var(--clr-navy); line-height: 1; margin-bottom: 4px; }
  .location-card__badge { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; color: var(--clr-gold-dark); letter-spacing: 0.05em; }
  
  .location-card__divider { height: 1px; background: var(--clr-light-gray); }
  .location-card__branch { font-family: var(--font-body); font-size: var(--text-sm); font-weight: 700; color: var(--clr-navy); text-transform: uppercase; letter-spacing: 0.1em; }
  .location-card__address { font-style: normal; font-size: var(--text-base); color: var(--clr-text-body); line-height: 1.6; font-weight: 300; }
  
  .location-card__services { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .location-card__services span { font-size: 0.7rem; color: var(--clr-gold); background: var(--clr-gold-pale); padding: 4px 10px; border-radius: var(--radius-pill); font-weight: 600; }
  
  .location-card__hours { font-size: var(--text-sm); color: var(--clr-text-mid); }
  .location-card__hours span { display: block; margin-bottom: 4px; }
  .location-card__btn { text-align: center; margin-top: var(--space-2); }
</style>
