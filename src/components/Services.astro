---
const services = [
  {
    title: "Dental Implants",
    desc: "Specialized in advanced restorative procedures including: Advanced Zygomatic Implants for less bone situations, Basal Implants, Bone Grafting, and Sinus lift Surgeries.",
    beforeImg: "/implants_before_1777794155254.png",
    afterImg: "/implants_after_1777794171891.png",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="2" width="6" height="10" rx="2"/><path d="M12 12v10M8 22h8"/></svg>`,
    link: "/treatments#implants"
  },
  {
    title: "Invisalign Clear aligners",
    desc: "Nearly invisible, custom-made clear aligners. View your final smile before starting. Removable for eating and brushing, fitting perfectly around your professional lifestyle.",
    beforeImg: "/invisalign_before_1777794186881.png",
    afterImg: "/invisalign_after_1777794202267.png",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10h10M7 14h10M5 6h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z"/></svg>`,
    link: "/treatments#orthodontics"
  },
  {
    title: "TMJ Treatment",
    desc: "Comprehensive diagnosis and treatment for Temporomandibular Joint (TMJ) disorders. Relieve jaw pain, headaches, and restore proper jaw function and alignment.",
    beforeImg: "https://images.unsplash.com/photo-1551076805-e1869033e561?auto=format&fit=crop&q=80&w=800",
    afterImg: "https://images.unsplash.com/photo-1606811841689-23dfddce3e95?auto=format&fit=crop&q=80&w=800",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
    link: "/treatments#tmj"
  }
];
---

<section id="services" class="services">
  <div class="services__header">
    <span class="services__super-label">Super speciality Experts</span>
    <span class="section__label">What We Treat</span>
    <h2 class="services__heading">Our Dental <em>Services</em></h2>
    <p class="services__sub">
      Comprehensive care across many specialisations — all under one trusted name.
    </p>
  </div>

  <div class="services__grid">
    {services.map((s, i) => (
      <a href={s.link} class="service-card-link-wrapper" data-cursor-hover>
        <article class="service-card" data-index={i}>
          <div class="service-card__split-container">
            <div class="service-card__before">
              <span class="service-card__status">Before</span>
              <div class="service-card__placeholder">Image Coming Soon</div>
            </div>
            <div class="service-card__after">
              <span class="service-card__status">After</span>
              <div class="service-card__placeholder">Image Coming Soon</div>
            </div>
            <div class="service-card__icon-badge" set:html={s.icon}></div>
          </div>
          <div class="service-card__content">
            <h3 class="service-card__title">{s.title}</h3>
            <p class="service-card__desc">{s.desc}</p>
            <div class="service-card__footer">
              <span class="service-card__link">
                Explore Treatment
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>

  <div class="services__cta">
    <a href="#contact" class="btn btn--primary" data-cursor-hover>
      Book an Appointment
    </a>
    <a href="tel:+918489488999" class="btn btn--navy" data-cursor-hover>
      +91 84894 88999
    </a>
  </div>
</section>

<style>
  .services {
    padding: var(--space-32) var(--gutter);
    background: var(--clr-off-white);
  }

  .services__super-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--clr-gold-dark);
    margin-bottom: var(--space-4);
    opacity: 0.9;
  }

  .services__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-16);
  }

  .services__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }
  .services__heading em {
    font-style: italic;
    color: var(--clr-gold-dark);
  }

  .services__sub {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--clr-text-body);
    line-height: 1.7;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
    max-width: var(--max-width);
    margin: 0 auto var(--space-16);
    align-items: flex-start; /* Align to top */
  }

  .service-card-link-wrapper {
    display: block;
    text-decoration: none;
    height: 100%;
  }

  .service-card {
    background: var(--clr-white);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--clr-light-gray);
    display: flex;
    flex-direction: column;
    height: 100%;
    margin: 0 !important;
    transform: none;
    transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s ease;
  }
  .service-card-link-wrapper:hover .service-card {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--clr-gold);
  }

  .service-card__split-container {
    height: 320px;
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--clr-off-white);
  }

  .service-card__before, .service-card__after {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .service-card__after {
    border-bottom: none;
    background: rgba(206, 196, 167, 0.1);
  }

  .service-card__status {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    background: rgba(0,0,0,0.4);
    color: white;
    border-radius: 4px;
    z-index: 2;
    backdrop-filter: blur(4px);
  }

  .service-card__after .service-card__status {
    background: var(--clr-gold);
    color: var(--clr-navy);
  }

  .service-card__placeholder {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--clr-text-mid);
    opacity: 0.5;
    text-align: center;
    padding: 0 10px;
  }

  .service-card__icon-badge {
    position: absolute;
    bottom: -24px;
    right: 24px;
    width: 52px;
    height: 52px;
    background: var(--clr-gold);
    color: var(--clr-navy);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(206, 196, 167, 0.3);
    z-index: 5;
    transition: transform 0.3s ease;
  }

  .service-card-link-wrapper:hover .service-card__icon-badge {
    transform: scale(1.1);
  }

  .service-card__content {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 280px; /* Force consistent content area height */
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--clr-navy);
    margin-bottom: var(--space-3);
    min-height: 3rem; /* Fixed height for title area */
    display: flex;
    align-items: center;
  }

  .service-card__desc {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.7;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-8);
    flex-grow: 1;
  }

  .service-card__footer {
    margin-top: auto;
    padding-top: var(--space-4);
    height: 40px; /* Fixed height for link area */
    display: flex;
    align-items: center;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-gold-dark);
    text-decoration: none;
    transition: gap 0.3s ease;
    white-space: nowrap;
  }
  .service-card__link:hover {
    gap: 12px;
  }

  .services__cta {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.services__header', {
    scrollTrigger: { trigger: '#services', start: 'top 82%' },
    y: 40, opacity: 0, duration: 1, ease: 'power3.out',
  });
  gsap.from('.service-card', {
    scrollTrigger: { trigger: '.services__grid', start: 'top 85%' },
    y: 20, opacity: 0, stagger: 0.05, duration: 0.8, ease: 'power3.out',
  });
  gsap.from('.services__cta', {
    scrollTrigger: { trigger: '.services__cta', start: 'top 90%' },
    y: 30, opacity: 0, duration: 0.8, ease: 'power3.out',
  });
</script>
