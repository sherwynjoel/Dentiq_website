---
---

<section id="contact" class="contact">
  <div class="contact__inner">
    <span class="section__label contact__label">Begin Your Journey</span>

    <h2 class="contact__heading">
      Ready to Live<br /><em>Pain-Free?</em>
    </h2>

    <p class="contact__sub">
      Consult with India's leading orofacial pain specialist.<br />
      Call or email us to schedule your first visit.
    </p>

    <div class="contact__methods">
      <a href="tel:+919884520520" class="contact__method" data-cursor-hover>
        <span class="contact__method-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
        </span>
        <span class="contact__method-value">+91 9884 520 520</span>
        <span class="contact__method-label">Call Us</span>
      </a>

      <a href="mailto:doctor@dilipdentalcentre.com" class="contact__method" data-cursor-hover>
        <span class="contact__method-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </span>
        <span class="contact__method-value">doctor@dilipdentalcentre.com</span>
        <span class="contact__method-label">Email Us</span>
      </a>

      <div class="contact__method">
        <span class="contact__method-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </span>
        <span class="contact__method-value">Mon–Sat: 9AM – 8PM</span>
        <span class="contact__method-label">Sun: 10AM – 8PM</span>
      </div>
    </div>

    <a href="tel:+919884520520" class="btn btn--light contact__cta" data-magnetic data-cursor-hover>
      Call to Book &nbsp;—&nbsp; +91 9884 520 520
    </a>

    <p class="contact__note">
      All consultations are handled with the utmost care and confidentiality.
    </p>
  </div>
</section>

<style>
  .contact {
    background: var(--clr-olive);
    padding: var(--space-32) var(--gutter);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact::before {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    border: 1px solid rgba(112, 126, 87, 0.15);
    pointer-events: none;
  }
  .contact::after {
    content: '';
    position: absolute;
    bottom: -20%;
    right: -5%;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    border: 1px solid rgba(235, 230, 214, 0.06);
    pointer-events: none;
  }

  .contact__inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact__label {
    color: var(--clr-sand-light) !important;
    opacity: 0.75;
  }

  .contact__heading {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--clr-cream);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }
  .contact__heading em {
    font-style: italic;
    color: var(--clr-sage);
  }

  .contact__sub {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--clr-sand-light);
    line-height: 1.75;
    margin-bottom: var(--space-16);
    opacity: 0.85;
  }

  .contact__methods {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
    width: 100%;
  }

  .contact__method {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-8);
    background: rgba(235, 230, 214, 0.06);
    border: 1px solid rgba(235, 230, 214, 0.12);
    border-radius: 6px;
    flex: 1;
    min-width: 180px;
    max-width: 260px;
    transition:
      background 0.3s ease,
      transform 0.35s var(--ease-out-expo),
      border-color 0.3s ease;
  }
  .contact__method:hover {
    background: rgba(235, 230, 214, 0.1);
    transform: translateY(-6px);
    border-color: rgba(112, 126, 87, 0.3);
  }

  .contact__method-icon {
    width: 28px;
    height: 28px;
    color: var(--clr-sage);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact__method-icon svg { width: 100%; height: 100%; }

  .contact__method-value {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--clr-cream);
    line-height: 1.3;
  }

  .contact__method-label {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-sand-light);
    font-weight: 300;
    opacity: 0.7;
  }

  .contact__cta {
    font-size: var(--text-sm);
    padding: var(--space-5) var(--space-10);
  }

  .contact__note {
    margin-top: var(--space-6);
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-sand-light);
    opacity: 0.45;
    letter-spacing: 0.08em;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.contact__inner > *', {
    scrollTrigger: { trigger: '#contact', start: 'top 78%' },
    opacity: 0,
    y: 30,
    stagger: 0.1,
    duration: 1,
    ease: 'power3.out',
  });

  // Magnetic CTA
  const cta = document.querySelector('.contact__cta') as HTMLElement;
  if (cta) {
    cta.addEventListener('mousemove', (e) => {
      const rect = cta.getBoundingClientRect();
      const dx = (e.clientX - (rect.left + rect.width  / 2)) * 0.28;
      const dy = (e.clientY - (rect.top  + rect.height / 2)) * 0.28;
      gsap.to(cta, { x: dx, y: dy, duration: 0.4, ease: 'power2.out' });
    });
    cta.addEventListener('mouseleave', () => {
      gsap.to(cta, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.4)' });
    });
  }
</script>
