---
---

<section id="contact" class="contact">
  <div class="contact__inner">

    <div class="contact__left">
      <span class="section__label section__label--light">Get In Touch</span>
      <h2 class="contact__heading">
        Book an Appointment<br /><em>Online or Offline</em>
      </h2>
      <div class="divider"></div>
      <p class="contact__desc">
        Consult with Erode's leading dental superspecialists. Call, email, or
        WhatsApp us to schedule your first visit at a time that suits you.
      </p>

      <div class="contact__methods">
        <a href="tel:+918489488999" class="contact__method" data-cursor-hover>
          <span class="contact__method-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <div>
            <span class="contact__method-label">Call Us</span>
            <span class="contact__method-value">+91 84894 88999</span>
          </div>
        </a>
        <a href="mailto:info@dentiqsuperspeciality.com" class="contact__method" data-cursor-hover>
          <span class="contact__method-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <div>
            <span class="contact__method-label">Email Us</span>
            <span class="contact__method-value">info@dentiqsuperspeciality.com</span>
          </div>
        </a>
        <a href="https://wa.me/918489488999" target="_blank" rel="noopener noreferrer" class="contact__method" data-cursor-hover>
          <span class="contact__method-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </span>
          <div>
            <span class="contact__method-label">WhatsApp</span>
            <span class="contact__method-value">Open WhatsApp Chat</span>
          </div>
        </a>
        <div class="contact__method">
          <span class="contact__method-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <div>
            <span class="contact__method-label">Working Hours</span>
            <span class="contact__method-value">Mon–Sat: 9AM–8PM · Sun: 10AM–8PM</span>
          </div>
        </div>
      </div>

      <div class="contact__locations-list">
        <div class="contact__loc">
          <strong style="color:white; font-size: 0.9rem; margin-bottom: 8px; display:block;">Hospital Headquarter — Erode</strong>
          <span style="display:block; text-align:left; font-size: 0.85rem; line-height: 1.6;">
            Palayapalayam, Near Perundurai Road,<br/>
            Erode, Tamilnadu — 638011
          </span>
        </div>
      </div>
    </div>

    <div class="contact__right">
      <div class="contact__form-card">
        <h3 class="contact__form-title">Book Online Consultation</h3>
        <p class="contact__form-sub">Fill in your details and we'll call you back shortly.</p>

        <form class="contact__form" id="contact-form" novalidate>
          <div class="contact__form-group">
            <label for="cf-name">Your Name *</label>
            <input type="text" id="cf-name" name="name" placeholder="e.g. Ravi Kumar" required />
          </div>
          <div class="contact__form-group">
            <label for="cf-phone">Phone Number *</label>
            <input type="tel" id="cf-phone" name="phone" placeholder="+91 98765 43210" required />
          </div>
          <div class="contact__form-group">
            <label for="cf-email">Email Address</label>
            <input type="email" id="cf-email" name="email" placeholder="you@example.com" />
          </div>
          <div class="contact__form-group">
            <label for="cf-service">Service Required</label>
            <select id="cf-service" name="service">
              <option value="">Select a service…</option>
              <option>Cosmetic Dentistry</option>
              <option>Implant Surgery</option>
              <option>Orthognathic Surgery</option>
              <option>Root Canal Therapy</option>
              <option>Invisalign / Aligners</option>
              <option>Kids Dentistry</option>
              <option>TMJ & Sleep Apnea</option>
              <option>Gum Care (Periodontics)</option>
              <option>Other</option>
            </select>
          </div>
          <div class="contact__form-group">
            <label for="cf-message">Message (Optional)</label>
            <textarea id="cf-message" name="message" rows="3" placeholder="Describe your concern briefly…"></textarea>
          </div>
          <button type="submit" class="btn btn--primary contact__form-submit" id="cf-submit">
            Request Appointment
          </button>
          <p class="contact__form-note">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--clr-gold-dark)" stroke-width="3" style="display:inline; margin-right:4px;"><polyline points="20 6 9 17 4 12"/></svg>
            All consultations are handled with care and confidentiality.
          </p>
        </form>
      </div>
    </div>

  </div>
</section>

<style>
  .contact {
    background: var(--clr-navy);
    padding: var(--space-32) var(--gutter);
    position: relative;
    overflow: hidden;
  }
  .contact::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.05);
    pointer-events: none;
  }
  .contact::after {
    content: '';
    position: absolute;
    bottom: -25%;
    left: -5%;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.03);
    pointer-events: none;
  }

  .contact__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  /* Left */
  .contact__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-white);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }
  .contact__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .contact__desc {
    font-size: var(--text-base);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: var(--space-8);
    max-width: 44ch;
  }

  .contact__methods {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .contact__method {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }
  .contact__method:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(206, 196, 167, 0.35);
    transform: translateX(6px);
  }

  .contact__method-icon {
    width: 42px;
    height: 42px;
    background: rgba(206, 196, 167, 0.15);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--clr-gold);
  }

  .contact__method-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-gold);
    margin-bottom: 2px;
  }

  .contact__method-value {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--clr-white);
    line-height: 1.3;
  }

  .contact__locations-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
  }

  .contact__loc {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-xs);
    flex-wrap: wrap;
  }
  .contact__loc strong {
    color: var(--clr-gold);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.7rem;
    flex-shrink: 0;
  }
  .contact__loc span {
    color: rgba(255,255,255,0.6);
    font-weight: 300;
    text-align: right;
  }

  /* Right – form card */
  .contact__form-card {
    background: var(--clr-white);
    border-radius: var(--radius-xl);
    padding: var(--space-10) var(--space-10);
    box-shadow: var(--shadow-lg);
  }

  .contact__form-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--clr-navy);
    margin-bottom: var(--space-2);
  }

  .contact__form-sub {
    font-size: var(--text-sm);
    color: var(--clr-text-mid);
    margin-bottom: var(--space-6);
    font-weight: 300;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact__form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact__form-group label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--clr-navy);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .contact__form-group input,
  .contact__form-group select,
  .contact__form-group textarea {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--clr-text-dark);
    background: var(--clr-off-white);
    border: 1.5px solid var(--clr-light-gray);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    resize: none;
  }
  .contact__form-group input:focus,
  .contact__form-group select:focus,
  .contact__form-group textarea:focus {
    border-color: var(--clr-gold-dark);
    box-shadow: 0 0 0 3px rgba(206, 196, 167, 0.12);
    background: var(--clr-white);
  }
  .contact__form-group input::placeholder,
  .contact__form-group textarea::placeholder {
    color: rgba(74, 96, 128, 0.5);
  }

  .contact__form-submit {
    width: 100%;
    justify-content: center;
    padding: 16px !important;
    font-size: var(--text-sm) !important;
    margin-top: var(--space-2);
  }

  .contact__form-note {
    font-size: var(--text-xs);
    color: var(--clr-text-mid);
    text-align: center;
    font-weight: 300;
    margin-top: var(--space-2);
  }

  @media (max-width: 900px) {
    .contact__inner { grid-template-columns: 1fr; gap: var(--space-12); }
    .contact__heading { font-size: 2.2rem; }
  }
  @media (max-width: 500px) {
    .contact { padding: var(--space-16) var(--gutter); }
    .contact__form-card { padding: var(--space-8) var(--space-6); }
    .contact__heading { font-size: 1.8rem; }
    .contact__desc { font-size: 0.95rem; }
    .contact__method { padding: var(--space-3) var(--space-4); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.contact__left > *', {
    scrollTrigger: { trigger: '#contact', start: 'top 78%' },
    x: -40, opacity: 0, stagger: 0.1, duration: 1, ease: 'power3.out',
  });
  gsap.from('.contact__form-card', {
    scrollTrigger: { trigger: '#contact', start: 'top 78%' },
    x: 40, opacity: 0, duration: 1, ease: 'power3.out',
  });

  // Form submission (demo)
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('cf-submit') as HTMLButtonElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    btn.textContent = '✓ Request Sent!';
    btn.style.background = '#228b45';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = 'Request Appointment';
      btn.style.background = '';
      btn.disabled = false;
      form.reset();
    }, 3500);
  });


</script>
