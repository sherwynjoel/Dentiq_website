---
import indianSmile1 from "C:/Users/Sherwyn joel/.gemini/antigravity/brain/428871a4-9722-43ce-9b86-ef882cfd310f/indian_smile_1_1777610291924.png";
import indianSmile2 from "C:/Users/Sherwyn joel/.gemini/antigravity/brain/428871a4-9722-43ce-9b86-ef882cfd310f/indian_smile_2_1777610372994.png";
import indianSmile3 from "C:/Users/Sherwyn joel/.gemini/antigravity/brain/428871a4-9722-43ce-9b86-ef882cfd310f/indian_smile_3_1777610388266.png";

const slides = [
  indianSmile1.src,
  indianSmile2.src,
  indianSmile3.src
];
---

<section id="hero" aria-label="Hero">
  <!-- Slideshow Backgrounds -->
  <div class="hero__slideshow">
    {slides.map((src, index) => (
      <div class={`hero__slide ${index === 0 ? 'active' : ''}`} style={`background-image: url('${src}')`}></div>
    ))}
  </div>

  <!-- Background gradient overlay -->
  <div class="hero__bg"></div>
  <div class="hero__pattern"></div>

  <div class="hero__grid">
    <div class="hero__left">
      <span class="section__label section__label--light">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Palayapalayam, Erode
      </span>
      <h1 class="hero__heading">
        DentiQ <em>Friendly</em> Laser Dental Care
      </h1>
      <p class="hero__sub">
        We are a caring team of dental experts ready to help you with comfortable, pain-free treatments. We make sure every visit leaves you with a happy, confident smile.
      </p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary" data-magnetic data-cursor-hover>
          Book Appointment
        </a>
        <a href="#contact" class="btn btn--free-consult" data-magnetic data-cursor-hover>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:8px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Free Consultation
        </a>
      </div>

      <!-- Stat row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">20+</span>
          <span class="hero__stat-label">Years Experience</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">3000+</span>
          <span class="hero__stat-label">Happy Patients</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">4.9 <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block; vertical-align:middle; margin-top:-4px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg></span>
          <span class="hero__stat-label">Google Rating</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">99%</span>
          <span class="hero__stat-label">Satisfaction</span>
        </div>
      </div>
    </div>


  </div>


</section>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 7rem var(--gutter) var(--space-20);
    overflow: hidden;
  }

  .hero__slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__slide {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out, transform 6s linear;
    transform: scale(1.05);
  }
  .hero__slide.active {
    opacity: 1;
    transform: scale(1);
  }

  /* Background texture */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)),
      linear-gradient(90deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 45%, rgba(255,255,255,0) 65%),
      radial-gradient(ellipse 60% 70% at 75% 50%, rgba(206,196,167,0.15) 0%, transparent 65%),
      radial-gradient(ellipse 40% 40% at 10% 80%, rgba(206,196,167,0.1) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(78,72,50,0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  /* Left */
  .hero__left {
    max-width: 650px;
  }
  .hero__heading {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    font-weight: 600;
    line-height: 1.08;
    color: var(--clr-navy);
    margin-bottom: var(--space-6);
    letter-spacing: -0.01em;
    opacity: 0;
  }
  .hero__heading em {
    font-style: italic;
    color: var(--clr-gold-dark);
  }

  .hero__sub {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.8;
    color: var(--clr-text-body);
    margin-bottom: var(--space-10);
    max-width: 50ch;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    opacity: 0;
  }
  .btn--free-consult {
    background: transparent;
    border: 1px solid var(--clr-navy);
    color: var(--clr-navy);
    padding: 12px 28px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    transition: all 0.3s ease;
  }
  .btn--free-consult:hover {
    background: var(--clr-navy);
    color: var(--clr-white);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 500px) {
    .hero__actions {
      flex-direction: column;
      width: 100%;
    }
    .hero__actions .btn {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }

  /* Stats row */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    opacity: 0;
    padding: var(--space-6) var(--space-8);
    background: var(--clr-white);
    border: 1px solid var(--clr-light-gray);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-sm);
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    min-width: 80px;
  }
  .hero__stat-num {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--clr-navy);
    line-height: 1;
  }
  .hero__stat-label {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-text-mid);
    text-align: center;
  }
  .hero__stat-divider {
    width: 1px;
    height: 36px;
    background: var(--clr-light-gray);
    flex-shrink: 0;
  }


  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 52px;
    overflow: hidden;
    display: block;
  }
  .hero__scroll-line span {
    display: block;
    width: 1px;
    height: 100%;
    background: var(--clr-navy);
    animation: scroll-drop 2s ease-in-out infinite;
  }
  @keyframes scroll-drop {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    #hero { align-items: flex-start; padding-top: 8.5rem; min-height: auto; padding-bottom: 6rem; }
    .hero__grid { grid-template-columns: 1fr; gap: var(--space-10); }
    .hero__heading { font-size: 2.8rem; line-height: 1.1; }
    .hero__sub { font-size: 1.1rem; }
  }
  @media (max-width: 600px) {
    .hero__stats { 
      gap: var(--space-4); 
      padding: var(--space-4); 
      display: grid;
      grid-template-columns: 1fr 1fr;
      text-align: center;
    }
    .hero__stat-divider { display: none; }
    .hero__heading { font-size: 1.8rem; letter-spacing: -0.02em; }
    .hero__sub { font-size: 0.95rem; line-height: 1.7; margin-bottom: var(--space-8); }
    .hero__stat-num { font-size: 1.3rem; }
    .hero__stat-label { font-size: 0.6rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('loader:complete', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl
      .to('.section__label', { opacity: 1, y: 0, duration: 0.5 })
      .to('.hero__heading', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3')
      .to('.hero__sub',     { opacity: 1, duration: 0.5 }, '-=0.4')
      .to('.hero__actions', { opacity: 1, duration: 0.5 }, '-=0.4')
      .to('.hero__stats',   { opacity: 1, y: 0, duration: 0.5 }, '-=0.4')
      .to('.hero__scroll-hint', { opacity: 1, duration: 0.4 }, '-=0.2');
  });

  // Initial state
  gsap.set(['.hero__heading','.hero__stats'], { y: 40 });

  // Slideshow Logic
  const slideElements = document.querySelectorAll('.hero__slide');
  let currentSlide = 0;
  if(slideElements.length > 1) {
    setInterval(() => {
      slideElements[currentSlide].classList.remove('active');
      currentSlide = (currentSlide + 1) % slideElements.length;
      slideElements[currentSlide].classList.add('active');
    }, 5000);
  }

  // Parallax on scroll
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'top top',
    end: 'bottom top',
    onUpdate(self) {
      gsap.set('.hero__bg', { y: self.progress * 80 });
    },
  });


</script>
