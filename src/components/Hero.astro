---
const slides = [
  '/hero-bg-1.webp',
  '/hero-bg-2.webp',
  '/hero-bg-3.webp',
];
---

<section id="hero" aria-label="Hero">
  <!-- Slideshow Backgrounds -->
  <div class="hero__slideshow">
    {slides.map((src, index) => (
      <div class={`hero__slide ${index === 0 ? 'active' : ''}`} style={`background-image: url('${src}')`}></div>
    ))}
  </div>

  <!-- Background gradient overlay -->
  <div class="hero__bg"></div>
  <div class="hero__pattern"></div>

  <div class="hero__grid">
    <div class="hero__left">
      <span class="section__label section__label--light">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Palayapalayam, Erode
      </span>
      <h1 class="hero__heading">
        Friendly Laser Dental Care <em>in Erode</em>
      </h1>
      <p class="hero__sub">
        Advanced dental care for implants, smile design, root canals, gum health, and child dentistry, delivered with calm communication and modern clinical comfort.
      </p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary" data-magnetic data-cursor-hover>
          Book Appointment
        </a>
        <a href="/treatments" class="btn btn--free-consult" data-cursor-hover>
          View Treatments
        </a>
      </div>

      <div class="hero__trust-row" aria-label="Clinic highlights">
        <span>Laser Dentistry</span>
        <span>Implants</span>
        <span>Smile Design</span>
        <span>Kids Dental Care</span>
      </div>

      <!-- Stat row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">23+</span>
          <span class="hero__stat-label">Years Experience</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">10000+</span>
          <span class="hero__stat-label">Happy Families</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">4.9 <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block; vertical-align:middle; margin-top:-4px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg></span>
          <span class="hero__stat-label">Google Rating</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">99%</span>
          <span class="hero__stat-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <div class="hero__right">
      <div class="hero__image-wrapper">
        <img src="/dr-dilip.webp" alt="Dr. Dilip - Lead Dental Specialist" class="hero__doctor-img" />
        <div class="hero__doctor-info">
          <strong>Dr. Dilip, MDS</strong>
          <span>Oral & Maxillofacial Specialist</span>
        </div>
      </div>
    </div>
  </div>


</section>

<style>
  #hero {
    position: relative;
    height: 100svh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 8.5rem var(--gutter) 2rem;
    overflow: hidden;
  }

  .hero__slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__slide {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out, transform 8s linear;
    transform: scale(1.08);
  }
  .hero__slide.active {
    opacity: 1;
    transform: scale(1);
  }

  /* Background texture */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(250,246,240,0.94) 0%, rgba(250,246,240,0.85) 44%, rgba(250,246,240,0.56) 100%),
      radial-gradient(ellipse 70% 70% at 50% 45%, rgba(250,246,240,0.34) 0%, transparent 72%),
      linear-gradient(to bottom, rgba(45,53,42,0.03), rgba(45,53,42,0.18));
    pointer-events: none;
    z-index: 0;
  }
  .hero__pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(78,72,50,0.065) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column; /* Force vertical stacking on mobile */
    justify-content: center;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    text-align: center;
  }

  @media (min-width: 1025px) {
    .hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-12);
      align-items: center;
      text-align: left;
      margin-top: 5rem; /* Pushed down further for a perfectly relaxed, centered layout */
    }
  }

  /* Left */
  .hero__left {
    max-width: 860px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 1025px) {
    .hero__left {
      align-items: flex-start;
      text-align: left;
    }
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4.8vw, 4rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--clr-navy);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
    opacity: 0;
  }
  .hero__heading em {
    font-style: italic;
    color: var(--clr-gold-dark);
  }

  .hero__sub {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.7;
    color: var(--clr-text-dark);
    margin-bottom: var(--space-4);
    max-width: 64ch;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    opacity: 0;
  }

  @media (min-width: 1025px) {
    .hero__actions {
      justify-content: flex-start;
    }
  }

  .btn--free-consult {
    background: transparent;
    border: 1px solid rgba(78,72,50,0.35);
    color: var(--clr-navy);
    padding: 12px 24px;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    transition: all 0.3s ease;
  }
  .btn--free-consult:hover {
    background: var(--clr-navy);
    color: var(--clr-white);
    box-shadow: var(--shadow-md);
  }

  .hero__trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    opacity: 0;
  }

  @media (min-width: 1025px) {
    .hero__trust-row {
      justify-content: flex-start;
    }
  }
  .hero__trust-row span {
    padding: 6px 12px;
    border: 1px solid rgba(78, 72, 50, 0.14);
    border-radius: var(--radius-pill);
    background: rgba(252, 250, 246, 0.72);
    color: var(--clr-navy);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  /* Stats row */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    opacity: 0;
    padding: var(--space-4) var(--space-6);
    background: rgba(252, 250, 246, 0.88);
    border: 1px solid rgba(78,72,50,0.12);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(16px);
    box-shadow: 0 12px 48px rgba(78,72,50,0.14);
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    min-width: 80px;
  }
  .hero__stat-num {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--clr-navy);
    line-height: 1;
  }
  .hero__stat-label {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-text-mid);
    text-align: center;
  }
  .hero__stat-divider {
    width: 1px;
    height: 28px;
    background: var(--clr-light-gray);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    #hero { align-items: flex-start; padding-top: 10rem; height: auto; min-height: auto; padding-bottom: 8rem; }
    .hero__heading { font-size: 3.5rem; line-height: 1.1; }
    .hero__sub { font-size: 1.1rem; }
  }
  @media (max-width: 768px) {
    .hero__heading { font-size: 2.8rem; }
    .hero__stats { 
      padding: var(--space-6); 
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6) var(--space-4);
    }
    .hero__stat-divider { display: none; }
  }
  @media (max-width: 500px) {
    #hero { padding-top: 8rem; }
    .hero__heading { font-size: 2.2rem; letter-spacing: -0.01em; }
    .hero__sub { font-size: 0.95rem; line-height: 1.7; margin-bottom: var(--space-8); }
    .hero__stat-num { font-size: 1.4rem; }
    .hero__stat-label { font-size: 0.65rem; }
    .hero__trust-row { justify-content: center; gap: 8px; }
    .hero__trust-row span { font-size: 0.6rem; padding: 5px 10px; }
    .hero__actions {
      flex-direction: column;
      width: 100%;
    }
    .hero__actions .btn {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }

  .hero__right {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  @media (min-width: 1025px) {
    .hero__right {
      justify-content: flex-end;
      align-items: center;
      width: 100%;
      margin-top: 0.5rem; /* Balanced parallel alignment alongside the grid margin */
      margin-bottom: 0;
    }
  }
  .hero__image-wrapper {
    position: relative;
    width: 100%;
    max-width: 360px; /* Reduced slightly to prevent crowding on medium desktop screens */
    aspect-ratio: 2.8 / 4;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg), 0 20px 48px rgba(45, 53, 42, 0.22);
    border: 2px solid var(--clr-gold);
    background: var(--clr-off-white);
  }
  .hero__doctor-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .hero__image-wrapper:hover .hero__doctor-img {
    transform: scale(1.04);
  }
  .hero__doctor-info {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    right: var(--space-4);
    background: rgba(250, 246, 240, 0.94);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(206, 196, 167, 0.35);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    text-align: left;
  }
  .hero__doctor-info strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--clr-navy);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .hero__doctor-info span {
    display: block;
    font-size: 0.72rem;
    color: var(--clr-text-mid);
    margin-top: 2px;
    font-weight: 500;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('loader:complete', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl
      .to('.section__label', { opacity: 1, y: 0, duration: 0.5 })
      .to('.hero__heading', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3')
      .to('.hero__sub',     { opacity: 1, duration: 0.5 }, '-=0.4')
      .to('.hero__actions', { opacity: 1, duration: 0.5 }, '-=0.4')
      .to('.hero__trust-row', { opacity: 1, duration: 0.45 }, '-=0.35')
      .to('.hero__stats',   { opacity: 1, y: 0, duration: 0.5 }, '-=0.4')
      .to('.hero__image-wrapper', { opacity: 1, x: 0, rotateY: 0, duration: 1 }, '-=0.8')
      .to('.hero__doctor-info', { opacity: 1, y: 0, duration: 0.6 }, '-=0.4')
      .to('.hero__scroll-hint', { opacity: 1, duration: 0.4 }, '-=0.2');
  });

  // Initial state
  gsap.set(['.hero__heading','.hero__stats'], { y: 40 });
  gsap.set('.hero__image-wrapper', { opacity: 0, x: 30, rotateY: -10 });
  gsap.set('.hero__doctor-info', { opacity: 0, y: 20 });

  // Slideshow Logic
  const slideElements = document.querySelectorAll('.hero__slide');
  let currentSlide = 0;
  if(slideElements.length > 1) {
    setInterval(() => {
      slideElements[currentSlide].classList.remove('active');
      currentSlide = (currentSlide + 1) % slideElements.length;
      slideElements[currentSlide].classList.add('active');
    }, 5000);
  }

  // Parallax on scroll
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'top top',
    end: 'bottom top',
    onUpdate(self) {
      gsap.set('.hero__bg', { y: self.progress * 80 });
    },
  });
</script>
