---
const needs = [
  { href: '/treatments/implants', title: "Missing Teeth", desc: "Permanent replacement with implant dentistry.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 2C8 2 4 5.5 4 9c0 2.5 1.5 4.5 3 6l1 5h8l1-5c1.5-1.5 3-3.5 3-6 0-3.5-4-7-8-7zM7 9h10M12 2v7"/></svg>` },
  { href: '/treatments/orthodontics', title: "Crooked Teeth", desc: "Straighten teeth with aligners or braces.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M3 9h18M3 15h18M8 3v18M16 3v18"/></svg>` },
  { href: '/treatments/endodontics', title: "Tooth Pain", desc: "Root canal care for painful decayed teeth.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>` },
  { href: '/treatments/periodontics', title: "Bleeding Gums", desc: "Gum treatment, cleaning, and laser care.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>` },
  { href: '/treatments/cosmetic', title: "Discolored Teeth", desc: "Whitening and smile-design treatments.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg>` },
  { href: '/treatments/prosthodontics', title: "Broken Teeth", desc: "Crowns, bridges, and full-mouth restoration.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M21 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2"/><path d="M3 7l9 5 9-5M12 12v9"/></svg>` },
  { href: '/treatments/conservative', title: "Black Cavities", desc: "Decay removal and tooth-colored fillings.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3" fill="currentColor"/></svg>` },
  { href: '/treatments/cosmetic', title: "Unpleasant Smile?", desc: "Full smile transformation and veneers.", icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 21s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 7.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="9" r="3"/></svg>` }
];
---

<section id="needs" class="needs">
  <div class="needs__inner">
    <div class="needs__header">
      <span class="section__label section__label--light">Your Treatment Need?</span>
      <h2 class="needs__heading">Which dental concern can we <em>Resolve</em> for you?</h2>
      <p class="needs__sub">Click on a concern to learn more about our superspeciality solutions.</p>
    </div>

    <div class="needs__grid">
      {needs.map((need) => (
        <a href={need.href} class="need-card" data-cursor-hover>
          <div class="need-card__icon" set:html={need.icon}></div>
          <div class="need-card__content">
            <h3>{need.title}</h3>
            <p>{need.desc}</p>
          </div>
          <div class="need-card__arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .needs {
    background: var(--clr-white);
    color: var(--clr-navy);
    padding: var(--space-32) var(--gutter);
    position: relative;
    overflow: hidden;
  }
  .needs::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 10% 90%, rgba(0,0,0,0.01) 0%, transparent 50%);
    pointer-events: none;
  }

  .needs__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .needs__header {
    text-align: center;
    margin-bottom: var(--space-16);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .needs__heading {
    font-size: var(--text-3xl);
    color: var(--clr-navy);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }
  .needs__heading em {
    color: var(--clr-gold-dark);
    font-style: italic;
  }
  .needs__sub {
    font-size: var(--text-base);
    color: var(--clr-text-body);
    font-weight: 300;
  }

  .needs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-5);
  }

  .need-card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--clr-off-white);
    border: 1px solid var(--clr-light-gray);
    border-radius: var(--radius-xl);
    text-decoration: none;
    height: 100%;
    transition: background 0.4s var(--ease-out-expo), border-color 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    position: relative;
  }
  .need-card:hover {
    background: var(--clr-white);
    border-color: var(--clr-gold);
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .need-card__icon {
    width: 60px;
    height: 60px;
    background: var(--clr-gold-pale);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-gold-dark);
    flex-shrink: 0;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .need-card:hover .need-card__icon {
    background: var(--clr-gold);
    color: var(--clr-white);
  }

  .need-card__content h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--clr-navy);
    margin-bottom: 4px;
    transition: color 0.3s ease;
  }
  .need-card__content p {
    font-size: var(--text-sm);
    color: var(--clr-text-mid);
    line-height: 1.5;
    font-weight: 300;
  }
  .need-card:hover .need-card__content h3 { color: var(--clr-gold-dark); }

  .need-card__arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%) translateX(10px);
    color: var(--clr-gold-dark);
    opacity: 0;
    transition: all 0.3s ease;
  }
  .need-card:hover .need-card__arrow {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  @media (max-width: 768px) {
    .needs { padding: var(--space-16) var(--gutter); }
    .needs__grid { grid-template-columns: 1fr; }
    .needs__heading { font-size: 1.8rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.need-card', {
    scrollTrigger: {
      trigger: '.needs__grid',
      start: 'top 95%'
    },
    y: 20,
    opacity: 0,
    stagger: 0.05,
    duration: 0.6,
    ease: 'power3.out'
  });
</script>
