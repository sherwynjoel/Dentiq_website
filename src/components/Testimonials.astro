---
const testimonials = [
  { text: "Initially I came here with TMJ issue for past 2 years. I visited other dentists but those treatments did not give me proper cure but now I am completely cured. Trust me — visit Dr. Jane and she will thoroughly analyse the issue and give you proper treatment.", name: "Harsha Baskaran", city: "Chennai", stars: 5 },
  { text: "I had severe jaw pain and facial pains for more than 5 years. I visited many specialists — ENT, ortho, neurologist. Came to know about Dr. Jane from Instagram. After 4 weeks of treatment I am totally pain free. I have never been this happy.", name: "Deepikask", city: "Chennai", stars: 5 },
  { text: "Doctor John is so experienced that he gave me the best solution without surgery. He was gentle and attentive. Post removal they called the next morning to check if everything was okay. None of the dental centres do this.", name: "Nadir Farhan", city: "Chennai", stars: 5 },
  { text: "With my recent root canal treatment, each member from the reception to dental assistant played an integral role in making my experience comfortable and smooth. Thank you all.", name: "Sunilkumar Balan", city: "Chennai", stars: 5 },
  { text: "Totally advanced X-ray technology. Laser root canal with absolutely no pain. Appointment fixed with our convenience. Overall had a great experience and will recommend this clinic.", name: "Pavithra Balachandran", city: "Chennai", stars: 5 },
  { text: "From past 5 years I was suffering with facial pains and headaches. After 5 weeks of treatment I am totally pain free. Thanks to Dr Jane mam. They treat patients very kindly.", name: "Rizwana Amanulla", city: "Chennai", stars: 5 },
];
---

<section id="testimonials" class="testimonials section--dark">
  <div class="testimonials__inner">
    <div class="testimonials__header">
      <span class="section__label section__label--light">Patient Stories</span>
      <h2 class="testimonials__heading">What Our <em>Patients Say</em></h2>
      <p class="testimonials__sub">
        250+ verified Google reviews &nbsp;·&nbsp; 4.9 <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> average rating
      </p>
    </div>

    <div class="testi-grid">
      {testimonials.map((t, i) => (
        <blockquote class={`testi-card ${i === 0 ? 'testi-card--featured' : ''}`}>
          <div class="testi-card__stars" aria-label="5 stars">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <p class="testi-card__text">"{t.text}"</p>
          <footer class="testi-card__footer">
            <div class="testi-card__avatar">
              {t.name.charAt(0)}
            </div>
            <div>
              <cite class="testi-card__name">{t.name}</cite>
              <span class="testi-card__city">{t.city}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <div class="testimonials__cta">
      <a
        href="https://www.google.com/search?q=dr+dilip+dental+centre+chennai"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--primary"
        data-cursor-hover
      >
        Read All Reviews on Google <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline-block; vertical-align:middle; margin-left:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--clr-white);
    padding: var(--space-32) var(--gutter);
  }

  .testimonials__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: var(--space-16);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }
  .testimonials__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .testimonials__sub {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--clr-text-mid);
    letter-spacing: 0.06em;
  }

  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  .testi-card {
    background: var(--clr-off-white);
    border: 1px solid var(--clr-light-gray);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      transform 0.35s var(--ease-out-expo);
  }
  .testi-card:hover {
    background: var(--clr-white);
    border-color: var(--clr-gold);
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
  }

  .testi-card--featured {
    background: var(--clr-gold);
    border-color: var(--clr-gold);
    grid-row: span 1;
  }
  .testi-card--featured:hover {
    background: var(--clr-gold-light);
    border-color: var(--clr-gold-light);
  }
  .testi-card--featured .testi-card__stars { color: var(--clr-navy); }
  .testi-card--featured .testi-card__text { color: var(--clr-navy); }
  .testi-card--featured .testi-card__name { color: var(--clr-navy); }
  .testi-card--featured .testi-card__city { color: rgba(78, 72, 50, 0.7); }
  .testi-card--featured .testi-card__avatar {
    background: var(--clr-navy);
    color: var(--clr-gold);
  }

  .testi-card__stars {
    color: var(--clr-gold);
    font-size: var(--text-sm);
    letter-spacing: 3px;
  }

  .testi-card__text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    font-weight: 300;
    line-height: 1.8;
    color: var(--clr-text-dark);
    flex: 1;
  }

  .testi-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .testi-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(78, 72, 50, 0.1);
    border: 1px solid rgba(78, 72, 50, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--clr-navy);
    flex-shrink: 0;
  }

  .testi-card__name {
    display: block;
    font-style: normal;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--clr-navy);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2px;
  }

  .testi-card__city {
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-text-mid);
    letter-spacing: 0.06em;
  }

  .testimonials__cta {
    text-align: center;
    margin-top: var(--space-4);
  }

  @media (max-width: 900px) {
    .testi-grid { grid-template-columns: 1fr; max-width: 540px; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 600px) {
    .testi-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.testimonials__header', {
    scrollTrigger: { trigger: '#testimonials', start: 'top 82%' },
    y: 30, opacity: 0, duration: 1, ease: 'power3.out',
  });
  gsap.from('.testi-card', {
    scrollTrigger: { trigger: '.testi-grid', start: 'top 85%' },
    y: 40, opacity: 0, stagger: 0.1, duration: 0.9, ease: 'power3.out',
  });
</script>
