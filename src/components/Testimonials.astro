---
const row1 = [
  { text: "Dr. Dhivya completely resolved my 3-year TMJ pain in just 6 sessions. The difference is life-changing.", name: "Priya R.", city: "Chennai" },
  { text: "Finally found a specialist who actually listened. The sleep dentistry experience was incredibly comfortable.", name: "Karthik M.", city: "Coimbatore" },
  { text: "After years of migraines, Dr. Dhivya's treatment gave me my life back. I cannot thank the team enough.", name: "Sruthi V.", city: "Chennai" },
  { text: "World-class care in Chennai. The clinic is immaculate and the team genuinely cares about your wellbeing.", name: "Ramesh A.", city: "Chennai" },
  { text: "My Invisalign journey was seamless. The results exceeded my expectations and the staff made it effortless.", name: "Divya S.", city: "Coimbatore" },
];

const row2 = [
  { text: "I was terrified of dentists until I came here. Now I actually look forward to my visits — truly remarkable.", name: "Ananya K.", city: "Chennai" },
  { text: "The root canal was completely painless. I was in and out comfortably. Professional to the highest degree.", name: "Suresh P.", city: "Coimbatore" },
  { text: "Dr. Dilip's expertise is matched only by his warmth. The entire team has an exceptional bedside manner.", name: "Meena T.", city: "Chennai" },
  { text: "99% satisfaction isn't just a statistic here — it's a lived promise. I'm a patient for life.", name: "Vikram N.", city: "Chennai" },
  { text: "The orofacial pain treatment transformed my daily life. Such deep expertise in a truly premium environment.", name: "Lakshmi B.", city: "Coimbatore" },
];
---

<section id="testimonials" class="testimonials">
  <div class="testimonials__header">
    <span class="section__label">Patient Stories</span>
    <h2 class="testimonials__heading">What Our <em>Patients Say</em></h2>
    <p class="testimonials__sub">
      3,000+ verified reviews &nbsp;·&nbsp; 4.9★ average rating
    </p>
  </div>

  <div class="testimonials__rows" aria-label="Patient testimonials">
    <!-- Row 1: scrolls left -->
    <div class="testimonials__row">
      <div class="testimonials__inner testimonials__inner--1">
        {[...row1, ...row1].map((t) => (
          <blockquote class="testi-card">
            <span class="testi-card__mark">"</span>
            <p>{t.text}</p>
            <cite>
              {t.name}
              <span>{t.city}</span>
            </cite>
            <div class="testi-card__stars">★★★★★</div>
          </blockquote>
        ))}
      </div>
    </div>

    <!-- Row 2: scrolls right -->
    <div class="testimonials__row">
      <div class="testimonials__inner testimonials__inner--2">
        {[...row2, ...row2].map((t) => (
          <blockquote class="testi-card">
            <span class="testi-card__mark">"</span>
            <p>{t.text}</p>
            <cite>
              {t.name}
              <span>{t.city}</span>
            </cite>
            <div class="testi-card__stars">★★★★★</div>
          </blockquote>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: var(--space-32) 0;
    background: var(--clr-sand-pale);
    overflow: hidden;
  }

  .testimonials__header {
    text-align: center;
    padding: 0 var(--gutter);
    margin-bottom: var(--space-16);
  }

  .testimonials__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--clr-olive);
  }
  .testimonials__heading em {
    font-style: italic;
    color: var(--clr-sage);
  }

  .testimonials__sub {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--clr-sage);
    letter-spacing: 0.08em;
  }

  .testimonials__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .testimonials__row { overflow: hidden; }

  .testimonials__inner {
    display: flex;
    gap: var(--space-5);
    width: max-content;
  }
  .testimonials__inner--1 {
    animation: marquee-left 50s linear infinite;
  }
  .testimonials__inner--2 {
    animation: marquee-left 60s linear infinite reverse;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials__inner { animation: none; }
  }

  .testimonials__inner:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .testi-card {
    flex-shrink: 0;
    width: 340px;
    padding: var(--space-8) var(--space-8);
    background: var(--clr-cream);
    border-radius: 4px;
    border: 1px solid rgba(206, 196, 167, 0.7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: box-shadow 0.3s ease;
  }
  .testi-card:hover { box-shadow: var(--shadow-card); }

  .testi-card__mark {
    font-family: var(--font-display);
    font-size: 4.5rem;
    color: var(--clr-sage);
    opacity: 0.25;
    line-height: 0.6;
    display: block;
  }

  .testi-card p {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-style: italic;
    font-weight: 300;
    line-height: 1.75;
    color: var(--clr-olive);
    flex: 1;
  }

  .testi-card cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--clr-sage);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .testi-card cite span {
    font-weight: 300;
    color: var(--clr-olive);
    opacity: 0.6;
    letter-spacing: 0.06em;
    text-transform: none;
  }

  .testi-card__stars {
    color: var(--clr-gold);
    font-size: var(--text-sm);
    letter-spacing: 3px;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.testimonials__header', {
    scrollTrigger: { trigger: '#testimonials', start: 'top 82%' },
    opacity: 0,
    y: 30,
    duration: 1,
    ease: 'power3.out',
  });

  gsap.from('.testimonials__rows', {
    scrollTrigger: { trigger: '#testimonials', start: 'top 78%' },
    opacity: 0,
    duration: 0.8,
    ease: 'power2.out',
  });
</script>
