---
---

<section id="stats" class="stats">
  <div class="stats__inner">
    <div class="stats__split">
      
      <!-- Left Side: Text & Reasons -->
      <div class="stats__left">
        <span class="section__label section__label--light">What Sets Us Apart</span>
        <h2 class="stats__heading">Why Choose <em>Dentiq</em></h2>
        <div class="divider"></div>
        <p class="stats__intro">
          We combine advanced technology with personalized care to deliver the best dental experience possible. Every patient receives a custom, evidence-based care plan tailored to their needs.
        </p>

        <div class="stats__reasons">
          <div class="stats__reason">
            <div class="stats__reason-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h4>Top-Rated Orofacial Pain Centre</h4>
              <p>India's leading specialist for TMJ, migraine, and orofacial disorders.</p>
            </div>
          </div>
          <div class="stats__reason">
            <div class="stats__reason-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h4>Advanced Technology</h4>
              <p>State-of-the-art 3D X-ray, laser dentistry, and digital smile design.</p>
            </div>
          </div>
          <div class="stats__reason">
            <div class="stats__reason-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h4>International Patients Welcome</h4>
              <p>Serving patients from across India and abroad with world-class comfort.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side: Stats Grid -->
      <div class="stats__right">
        <div class="stats__grid">

          <div class="stats__card">
            <div class="stats__card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 21v-2a4 4 0 0 1 8 0v2"/><circle cx="12" cy="11" r="4"/><path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2M4.93 19.07l1.41-1.41"/><path d="M5 3 3 6h18l-2-3"/></svg>
            </div>
            <div class="stats__num-wrap">
              <span class="stats__num" data-target="23">0</span><span class="stats__num-suffix">+</span>
            </div>
            <p class="stats__label">Years of Experience</p>
          </div>

          <div class="stats__card stats__card--featured">
            <div class="stats__card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="stats__num-wrap">
              <span class="stats__num" data-target="10000">0</span><span class="stats__num-suffix">+</span>
            </div>
            <p class="stats__label">Happy Patients</p>
          </div>

          <div class="stats__card">
            <div class="stats__card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div class="stats__num-wrap">
              <span class="stats__num" data-target="40">0</span><span class="stats__num-suffix">+</span>
            </div>
            <p class="stats__label">Specialists</p>
          </div>

          <div class="stats__card stats__card--offset">
            <div class="stats__card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <div class="stats__num-wrap">
              <span class="stats__num" data-target="99">0</span><span class="stats__num-suffix">%</span>
            </div>
            <p class="stats__label">Satisfaction Rate</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--clr-navy);
    padding: var(--space-32) var(--gutter);
    overflow: hidden;
  }

  .stats__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .stats__split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-20);
    align-items: center;
  }

  /* LEFT SIDE */
  .stats__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .stats__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-white);
    line-height: 1.1;
  }
  .stats__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .stats__intro {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: var(--space-6);
    font-weight: 300;
  }

  .stats__reasons {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .stats__reason {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .stats__reason-icon {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--clr-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .stats__reason h4 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--clr-white);
    margin-bottom: 4px;
  }
  .stats__reason p {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
  }

  /* RIGHT SIDE */
  .stats__right {
    position: relative;
    padding: var(--space-8) 0;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .stats__card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    transition: transform 0.4s var(--ease-out-expo), border-color 0.4s ease, background 0.4s ease;
  }
  .stats__card:hover {
    transform: translateY(-8px) scale(1.02);
    border-color: var(--clr-gold);
    background: rgba(255, 255, 255, 0.08);
  }

  .stats__card--featured {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--clr-gold);
    transform: translateY(30px);
  }
  .stats__card--featured:hover {
    transform: translateY(22px) scale(1.02);
  }

  .stats__card--offset {
    transform: translateY(30px);
  }
  .stats__card--offset:hover {
    transform: translateY(22px) scale(1.02);
  }

  .stats__card-icon {
    width: 50px;
    height: 50px;
    background: rgba(206, 196, 167, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--clr-gold);
  }

  .stats__num-wrap {
    display: flex;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .stats__num {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--clr-gold);
    line-height: 1;
  }
  .stats__num-suffix {
    font-family: var(--font-body);
    font-size: clamp(1.5rem, 2.5vw, 1.8rem);
    font-weight: 700;
    color: var(--clr-gold);
    margin-left: 2px;
  }

  .stats__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-white);
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 1024px) {
    .stats__split {
      grid-template-columns: 1fr;
      gap: var(--space-16);
    }
    .stats__card--featured, .stats__card--offset {
      transform: none;
    }
    .stats__card--featured:hover, .stats__card--offset:hover {
      transform: translateY(-8px) scale(1.02);
    }
  }
  @media (max-width: 500px) {
    .stats__grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.stats__left', {
    scrollTrigger: { trigger: '#stats', start: 'top 85%' },
    x: -40, opacity: 0, duration: 1, ease: 'power3.out',
  });

  gsap.from('.stats__card', {
    scrollTrigger: { trigger: '.stats__grid', start: 'top 85%' },
    y: 50, opacity: 0, stagger: 0.15, duration: 1, ease: 'power3.out',
  });

  ScrollTrigger.create({
    trigger: '.stats__grid',
    start: 'top 80%',
    once: true,
    onEnter() {
      document.querySelectorAll('[data-target]').forEach((el) => {
        const target = parseInt((el as HTMLElement).dataset.target || '0');
        gsap.to({ val: 0 }, {
          val: target,
          duration: 2.2,
          ease: 'power2.out',
          onUpdate() {
            el.textContent = Math.round((this as any).targets()[0].val).toLocaleString();
          },
        });
      });
    },
  });
</script>
