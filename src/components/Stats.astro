---
---

<section id="stats" class="stats section--light">
  <div class="stats__inner">
    <div class="stats__label-row">
      <span class="section__label">What Sets Us Apart</span>
    </div>
    <h2 class="stats__heading">Why Choose <em>Dentiq</em></h2>
    <div class="divider" style="margin:0 auto var(--space-12);"></div>

    <div class="stats__grid">

      <div class="stats__card">
        <div class="stats__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M8 21v-2a4 4 0 0 1 8 0v2"/><circle cx="12" cy="11" r="4"/><path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2M4.93 19.07l1.41-1.41"/><path d="M5 3 3 6h18l-2-3"/></svg>
        </div>
        <span class="stats__num" data-target="20">0</span><span class="stats__num-suffix">+</span>
        <p class="stats__label">Years of Experience</p>
        <p class="stats__desc">Two decades of excellence in dentistry and orofacial pain treatment.</p>
      </div>

      <div class="stats__card stats__card--featured">
        <div class="stats__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <span class="stats__num" data-target="3000">0</span><span class="stats__num-suffix">+</span>
        <p class="stats__label">Happy Patients</p>
        <p class="stats__desc">Thousands of patients experience pain-free lives thanks to our treatment.</p>
      </div>

      <div class="stats__card">
        <div class="stats__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <span class="stats__num" data-target="40">0</span><span class="stats__num-suffix">+</span>
        <p class="stats__label">Specialist Doctors</p>
        <p class="stats__desc">A multidisciplinary team of dentists, neurologists and physiotherapists.</p>
      </div>

      <div class="stats__card">
        <div class="stats__card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <span class="stats__num" data-target="99">0</span><span class="stats__num-suffix">%</span>
        <p class="stats__label">Satisfaction Rate</p>
        <p class="stats__desc">Consistently rated among India's top dental care providers on Google.</p>
      </div>

    </div>

    <!-- Why choose us bullets -->
    <div class="stats__reasons">
      <div class="stats__reason">
        <div class="stats__reason-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h4>Top-Rated Orofacial Pain Centre</h4>
          <p>India's leading specialist for TMJ, migraine, and orofacial disorders.</p>
        </div>
      </div>
      <div class="stats__reason">
        <div class="stats__reason-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h4>Advanced Technology</h4>
          <p>State-of-the-art 3D X-ray, laser dentistry, and digital smile design.</p>
        </div>
      </div>
      <div class="stats__reason">
        <div class="stats__reason-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h4>Personalised Treatment Plans</h4>
          <p>Every patient receives a custom, evidence-based care plan tailored to their needs.</p>
        </div>
      </div>
      <div class="stats__reason">
        <div class="stats__reason-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h4>International Patients Welcome</h4>
          <p>Serving patients from across India and abroad with world-class comfort.</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .stats {
    background: var(--clr-off-white);
    padding: var(--space-32) var(--gutter);
  }

  .stats__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .stats__label-row { margin-bottom: var(--space-4); }

  .stats__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }
  .stats__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    margin: 0 0 var(--space-16);
  }

  .stats__card {
    background: var(--clr-white);
    border-radius: var(--radius-lg);
    padding: var(--space-10) var(--space-6);
    border: 1px solid var(--clr-light-gray);
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease-out-expo), box-shadow 0.35s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    height: 100%;
  }
  .stats__card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .stats__card--featured {
    background: var(--clr-navy);
    border-color: var(--clr-navy);
  }
  .stats__card--featured .stats__num,
  .stats__card--featured .stats__num-suffix,
  .stats__card--featured .stats__label {
    color: var(--clr-white);
  }
  .stats__card--featured .stats__desc { color: rgba(255,255,255,0.6); }
  .stats__card--featured .stats__card-icon { background: rgba(201,153,42,0.2); }

  .stats__card-icon {
    width: 56px;
    height: 56px;
    background: var(--clr-gold-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-3);
    color: var(--clr-gold);
  }

  .stats__num {
    font-family: var(--font-body);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    color: var(--clr-gold-dark);
    line-height: 1;
    display: inline;
  }
  .stats__num-suffix {
    font-family: var(--font-body);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--clr-gold-dark);
    display: inline;
  }

  .stats__label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--clr-navy);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--space-2);
  }

  .stats__desc {
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-text-mid);
    line-height: 1.7;
    max-width: 20ch;
    margin: 0 auto;
  }

  /* Reasons grid */
  .stats__reasons {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    text-align: left;
    max-width: 900px;
    margin: 0 auto;
  }

  .stats__reason {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--clr-white);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-6);
    border: 1px solid var(--clr-light-gray);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .stats__reason:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .stats__reason-icon {
    width: 32px;
    height: 32px;
    background: var(--clr-gold);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .stats__reason h4 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--clr-navy);
    margin-bottom: var(--space-1);
  }
  .stats__reason p {
    font-size: var(--text-xs);
    font-weight: 300;
    color: var(--clr-text-mid);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
    .stats__reasons { grid-template-columns: 1fr; }
  }
  @media (max-width: 500px) {
    .stats__grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate heading
  gsap.from('.stats__heading', {
    scrollTrigger: { trigger: '#stats', start: 'top 82%' },
    y: 30, opacity: 0, duration: 0.9, ease: 'power3.out',
  });

  // Animate cards
  gsap.from('.stats__card', {
    scrollTrigger: { trigger: '.stats__grid', start: 'top 85%' },
    y: 40, opacity: 0, stagger: 0.1, duration: 0.9, ease: 'power3.out',
  });

  // Count-up animation
  ScrollTrigger.create({
    trigger: '.stats__grid',
    start: 'top 80%',
    once: true,
    onEnter() {
      document.querySelectorAll('[data-target]').forEach((el) => {
        const target = parseInt((el as HTMLElement).dataset.target || '0');
        gsap.to({ val: 0 }, {
          val: target,
          duration: 2.2,
          ease: 'power2.out',
          onUpdate() {
            el.textContent = Math.round((this as any).targets()[0].val).toLocaleString();
          },
        });
      });
    },
  });

  // Reasons
  gsap.from('.stats__reason', {
    scrollTrigger: { trigger: '.stats__reasons', start: 'top 86%' },
    y: 30, opacity: 0, stagger: 0.12, duration: 0.8, ease: 'power3.out',
  });
</script>
