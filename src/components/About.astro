---
---

<section id="about" class="section about">
  <div class="about__inner">

    <!-- Left: Info cards column -->
    <div class="about__left">
      <div class="about__img-wrap">
        <img src="/Screenshot%202026-04-29%20221706.png" alt="Dr. Dilip performing dental procedure" class="about__img" />
        <!-- Floating experience badge -->
        <div class="about__exp-badge">
          <span class="about__exp-num">23+</span>
          <span class="about__exp-label">Years of<br/>Excellence</span>
        </div>
      </div>

      <!-- Mini stats below image -->
      <div class="about__mini-stats">
        <div class="about__mini-stat">
          <span class="about__mini-num">40+</span>
          <span class="about__mini-label">Specialists</span>
        </div>
        <div class="about__mini-stat">
          <span class="about__mini-num">10000+</span>
          <span class="about__mini-label">Happy Patients</span>
        </div>
        <div class="about__mini-stat">
          <span class="about__mini-num">99%</span>
          <span class="about__mini-label">Satisfaction</span>
        </div>
      </div>
    </div>

    <!-- Right: Text content -->
    <div class="about__right">
      <span class="section__label">Who We Are</span>
      <h2 class="about__heading">
        Personalised Treatment,<br /><em>Exceptional Care</em>
      </h2>
      <div class="divider"></div>
      <p class="about__body">
        DentiQ is Erode's trusted local Laser Dental Clinic, 
        pioneering comfortable dentistry and welcoming care with 
        a dedicated team of specialists.
      </p>
      <p class="about__body">
        Our clinical team brings together modern dental technology, sterile protocols,
        and patient-first communication for everything from routine care to advanced
        implants, smile design, root canals, and child dentistry.
      </p>

      <!-- Awards list -->
      <ul class="about__awards">
        <li class="about__award">
          <span class="about__award-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg></span>
          <span>Laser dental care with a comfort-first treatment approach</span>
        </li>
        <li class="about__award">
          <span class="about__award-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg></span>
          <span>99% Client Satisfaction Rate</span>
        </li>
        <li class="about__award">
          <span class="about__award-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg></span>
          <span>Advanced sterilization and digital dental technology</span>
        </li>
        <li class="about__award">
          <span class="about__award-icon"><svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg></span>
          <span>Erode, Palayapalayam · 4.9 <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> Google Rating</span>
        </li>
      </ul>

      <a href="#contact" class="btn btn--primary about__cta" data-cursor-hover>
        Book Consultation <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline-block; vertical-align:middle; margin-left:4px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .about {
    background: var(--clr-navy);
    color: var(--clr-white);
  }

  .about__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-20);
    max-width: var(--max-width);
    margin: 0 auto;
    align-items: center;
  }

  /* ── Left column ── */
  .about__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about__img-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: visible;
  }

  .about__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
    min-height: 360px;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .about__exp-badge {
    position: absolute;
    bottom: -20px;
    right: -16px;
    background: var(--clr-gold);
    color: var(--clr-navy);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .about__exp-num {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1;
  }
  .about__exp-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.3;
    margin-top: 4px;
  }

  .about__mini-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .about__mini-stat {
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-4);
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .about__mini-stat:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
    border-color: var(--clr-gold);
  }
  .about__mini-num {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--clr-gold);
    line-height: 1;
    margin-bottom: 4px;
  }
  .about__mini-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── Right column ── */
  .about__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    line-height: 1.2;
    color: var(--clr-white);
    margin-bottom: var(--space-4);
  }
  .about__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .about__body {
    font-size: var(--text-base);
    font-weight: 400;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-5);
  }
  .about__body strong {
    color: var(--clr-gold);
    font-weight: 600;
  }

  .about__awards {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: var(--space-6) 0 var(--space-8);
  }
  .about__award {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.85);
  }
  .about__award-icon {
    color: var(--clr-gold);
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .about__cta { align-self: flex-start; }

  @media (max-width: 1024px) {
    .about__inner { grid-template-columns: 1fr; gap: var(--space-16); }
    .about__left  { order: 2; }
    .about__right { order: 1; }
    .about__exp-badge { right: 10px; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about__left', {
    scrollTrigger: { trigger: '.about__inner', start: 'top 85%' },
    x: -30, opacity: 0, duration: 0.6, ease: 'power2.out',
  });
  gsap.from('.about__right', {
    scrollTrigger: { trigger: '.about__inner', start: 'top 85%' },
    x: 30, opacity: 0, duration: 0.6, ease: 'power2.out',
  });
  gsap.from('.about__mini-stat', {
    scrollTrigger: { trigger: '.about__mini-stats', start: 'top 92%' },
    y: 20, opacity: 0, stagger: 0.05, duration: 0.5, ease: 'power2.out',
  });
</script>
