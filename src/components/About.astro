---
---

<section id="about" class="section about">
  <div class="about__inner">

    <div class="about__quote-col">
      <div class="about__quote-mark">"</div>
      <blockquote class="about__quote">
        Transforming lives through the science of pain — where precision
        meets compassion.
      </blockquote>
      <cite class="about__cite">
        Dr. Dhivya Dilipkumar
        <span>TMJ &amp; Orofacial Pain Specialist · Co-Founder</span>
      </cite>
      <div class="about__badge">
        <span class="about__badge-num">26+</span>
        <span class="about__badge-label">Years of Excellence</span>
      </div>
    </div>

    <div class="about__body-col">
      <span class="section__label">Our Philosophy</span>
      <h2 class="about__heading">
        Where Advanced Science<br /><em>Meets Compassionate Care</em>
      </h2>
      <p>
        Dr. Dilip Dental Centre pioneered specialised orofacial pain treatment
        in India. Our integrative approach combines advanced diagnostics with
        evidence-based care — treating not just teeth, but the complete
        orofacial system.
      </p>
      <p>
        With a team of 40+ specialists spanning dentistry, neurology, and
        physiotherapy, we bring world-class care to Chennai, Coimbatore, and
        soon Bangalore — all under one trusted name.
      </p>
      <div class="about__awards">
        <div class="about__award">
          <span class="about__award-icon">✦</span>
          <span>Best TMJ &amp; Orofacial Pain Centre in India</span>
        </div>
        <div class="about__award">
          <span class="about__award-icon">✦</span>
          <span>Board-Certified &amp; Accredited Hospital</span>
        </div>
        <div class="about__award">
          <span class="about__award-icon">✦</span>
          <span>99% Patient Satisfaction Rate</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .about {
    background: var(--clr-cream);
  }

  .about__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-24);
    max-width: var(--max-width);
    margin: 0 auto;
    align-items: start;
  }

  /* Quote column */
  .about__quote-col {
    background: var(--clr-sand-pale);
    border-radius: 4px;
    padding: var(--space-12) var(--space-10);
    position: relative;
    overflow: hidden;
  }
  .about__quote-col::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, var(--clr-sage), transparent);
  }

  .about__quote-mark {
    font-family: var(--font-display);
    font-size: 8rem;
    line-height: 0.6;
    color: var(--clr-sage);
    opacity: 0.18;
    margin-bottom: var(--space-4);
    font-weight: 300;
  }

  .about__quote {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.45;
    color: var(--clr-olive);
    quotes: none;
    margin-bottom: var(--space-8);
  }

  .about__cite {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--clr-olive);
    font-style: normal;
    letter-spacing: 0.04em;
  }
  .about__cite span {
    display: block;
    font-weight: 300;
    color: var(--clr-sage);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .about__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-8);
    padding: var(--space-3) var(--space-6);
    background: var(--clr-cream);
    border-radius: 100px;
    border: 1px solid var(--clr-sand-light);
  }
  .about__badge-num {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--clr-olive);
    line-height: 1;
  }
  .about__badge-label {
    font-size: var(--text-xs);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-sage);
  }

  /* Body column */
  .about__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: 1.2;
    color: var(--clr-olive);
    margin-bottom: var(--space-8);
  }
  .about__heading em {
    font-style: italic;
    color: var(--clr-sage);
  }

  .about__body-col p {
    margin-bottom: var(--space-6);
    font-weight: 300;
    line-height: 1.85;
    color: var(--clr-olive);
    opacity: 0.85;
  }

  .about__awards {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .about__award {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--clr-olive);
    opacity: 0.85;
  }
  .about__award-icon {
    color: var(--clr-sage);
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about__inner { grid-template-columns: 1fr; gap: var(--space-12); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about__quote-col', {
    scrollTrigger: { trigger: '.about__quote-col', start: 'top 82%' },
    x: -70,
    opacity: 0,
    duration: 1.3,
    ease: 'power3.out',
  });

  gsap.from('.about__body-col', {
    scrollTrigger: { trigger: '.about__body-col', start: 'top 82%' },
    x: 70,
    opacity: 0,
    duration: 1.3,
    ease: 'power3.out',
  });
</script>
