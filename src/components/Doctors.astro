---
---

<section id="doctors" class="section doctors">
  <div class="doctors__inner">
    <div class="doctors__header">
      <span class="section__label">The Specialists</span>
      <h2 class="doctors__heading">Our <em>Specialists</em> for every dental need</h2>
      <p class="doctors__sub">
        Expert superspecialists dedicated to solving complex dental ailments with global precision and local care.
      </p>
    </div>

    <div class="doctors__grid">



      <article class="doctor-card">
        <div class="doctor-card__avatar">
          <img src="/dr.png" alt="Dr. Bala Murugan" class="doctor-card__img" />
          <div class="doctor-card__avatar-ring"></div>
        </div>
        <div class="doctor-card__body">
          <span class="doctor-card__role">Lead Cosmetic Dentist & Maxillofacial Prosthodontist</span>
          <h3 class="doctor-card__name">Dr. Bala Murugan</h3>
          <p class="doctor-card__quals">MDS &nbsp;·&nbsp; Smile Design Specialist &nbsp;·&nbsp; 15+ Years</p>
          <p class="doctor-card__bio">
            A master of smile aesthetics who has completed thousands of life-changing transformations. 
            He specializes in premium no-prep veneers and lifelike artificial organ replacement.
          </p>
          <div class="doctor-card__tags">
            <span>Smile Design</span>
            <span>Veneers</span>
            <span>Prosthetics</span>
          </div>
        </div>
        <a href="#contact" class="doctor-card__cta btn btn--primary" data-cursor-hover>
          Book Appointment
        </a>
      </article>



    </div>
  </div>
</section>

<style>
  .doctors {
    background: var(--clr-white);
    padding: var(--space-32) var(--gutter);
  }

  .doctors__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .doctors__header {
    text-align: center;
    margin-bottom: var(--space-16);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .doctors__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }
  .doctors__heading em {
    font-style: italic;
    color: var(--clr-gold);
  }

  .doctors__sub {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--clr-text-mid);
    line-height: 1.7;
  }

  .doctors__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 420px;
    margin: 0 auto;
  }

  /* Card base */
  .doctor-card {
    background: var(--clr-off-white);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-8) var(--space-6);
    border: 1px solid var(--clr-light-gray);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-5);
    transition:
      transform 0.4s var(--ease-out-expo),
      box-shadow 0.4s ease,
      border-color 0.3s ease;
  }
  .doctor-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(201, 153, 42, 0.3);
  }

  /* Avatar */
  .doctor-card__avatar {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: var(--space-4);
  }
  .doctor-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .doctor-card__avatar--1 {
    background: linear-gradient(135deg, var(--clr-navy) 0%, var(--clr-navy-light) 100%);
    border-radius: var(--radius-lg);
  }
  .doctor-card__avatar--2 {
    background: linear-gradient(135deg, #1a4a2a 0%, #2d8050 100%);
    border-radius: var(--radius-lg);
  }
  .doctor-card__avatar-ring {
    position: absolute;
    inset: -5px;
    border-radius: calc(var(--radius-lg) + 4px);
    border: 2px solid var(--clr-gold);
    opacity: 0.5;
    transition: opacity 0.3s ease, inset 0.3s ease;
  }
  .doctor-card:hover .doctor-card__avatar-ring {
    opacity: 1;
    inset: -8px;
  }
  .doctor-card__initials {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--clr-white);
    letter-spacing: 0.05em;
  }

  /* Body content */
  .doctor-card__role {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clr-gold);
    margin-bottom: var(--space-2);
  }

  .doctor-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--clr-navy);
    line-height: 1.2;
    margin-bottom: var(--space-2);
  }

  .doctor-card__quals {
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--clr-text-mid);
    margin-bottom: var(--space-4);
    letter-spacing: 0.03em;
  }

  .doctor-card__bio {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.8;
    color: var(--clr-text-body);
    flex: 1;
  }

  /* Tag chips */
  .doctor-card__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }
  .doctor-card__tags span {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-navy);
    background: rgba(11, 37, 69, 0.08);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(11, 37, 69, 0.12);
  }
  .doctor-card__tags--light span {
    color: var(--clr-gold);
    background: var(--clr-gold-pale);
    border-color: rgba(201, 153, 42, 0.25);
  }

  .doctor-card__cta {
    font-size: var(--text-xs) !important;
    padding: 12px 24px !important;
    align-self: flex-start;
  }

  /* Team card */
  .doctor-card--team {
    background: var(--clr-navy);
    border-color: var(--clr-navy);
  }
  .doctor-card--team .doctor-card__name,
  .doctor-card--team .doctor-card__bio { color: var(--clr-white); }
  .doctor-card--team .doctor-card__bio { color: rgba(255,255,255,0.7); }
  .doctor-card--team .doctor-card__quals { color: rgba(255,255,255,0.5); }

  .doctor-card__team-num {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 700;
    color: var(--clr-white);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .doctor-card__team-num span { color: var(--clr-gold); }

  @media (max-width: 900px) {
    .doctors__grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.doctors__header', {
    scrollTrigger: { trigger: '#doctors', start: 'top 82%' },
    y: 30, opacity: 0, duration: 1, ease: 'power3.out',
  });
  gsap.from('.doctor-card', {
    scrollTrigger: { trigger: '.doctors__grid', start: 'top 84%' },
    y: 50, opacity: 0, stagger: 0.18, duration: 1.1, ease: 'power3.out',
  });
</script>
