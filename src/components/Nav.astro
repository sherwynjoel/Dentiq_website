---
const pathname = Astro.url?.pathname ?? '/';
const isHome       = pathname === '/' || pathname === '';
const isAbout      = pathname.startsWith('/about');
const isTreatments = pathname.startsWith('/treatments');
const isBlog       = pathname.startsWith('/blog');
const isContact    = pathname.startsWith('/contact');
---

<header id="nav" class={isHome ? 'is-home-nav' : ''} role="banner">
  <div class="nav__top-bar">
    <div class="nav__top-inner">
      <span class="nav__top-promo">New Patients — <a href="#contact" class="link-gold">Book Free Consultation</a></span>
      <div class="nav__top-contact">
        <a href="tel:+918489488999">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: middle;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +91 84894 88999
        </a>
        <a href="mailto:info@dentiqsuperspeciality.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: middle;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@dentiqsuperspeciality.com
        </a>
      </div>
    </div>
  </div>
  <nav class="nav__inner" aria-label="Main navigation">
    <a href="/" class="nav__logo" aria-label="DentiQ Home">
      <img src="/logo.png" alt="DentiQ Logo" class="nav__logo-img" />
    </a>

    <ul class="nav__links" role="list">
      <li><a href="/"           class={isHome       ? 'nav__active' : ''}>Home</a></li>
      <li><a href="/about"      class={isAbout      ? 'nav__active' : ''}>About</a></li>
      <li><a href="/treatments" class={isTreatments ? 'nav__active' : ''}>Treatments</a></li>
      <li><a href="/blog"       class={isBlog       ? 'nav__active' : ''}>Blog</a></li>
      <li>
        <a href="#contact" class="nav__cta" data-cursor-hover>Book Appointment</a>
      </li>
    </ul>

    <button
      class="nav__hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      id="nav-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

  <div id="nav-drawer" aria-hidden="true">
  <div class="drawer__inner">
    <ul role="list">
      <li><a href="/"           class="drawer__link">Home</a></li>
      <li><a href="/about"      class="drawer__link">About</a></li>
      <li><a href="/treatments" class="drawer__link">Treatments</a></li>
      <li><a href="/blog"       class="drawer__link">Blog</a></li>
      <li><a href="#contact"    class="drawer__link drawer__cta">Book Appointment</a></li>
    </ul>
    <p class="drawer__phone">+91 84894 88999</p>
  </div>
</div>

<style>
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background 0.4s ease, box-shadow 0.4s ease, padding 0.4s ease;
  }

  #nav.is-home-nav:not(.is-scrolled) .nav__links a {
    color: var(--clr-navy);
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__logo-img {
    filter: none;
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__links a:not(.nav__cta):hover {
    color: var(--clr-gold-dark);
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__links a.nav__active {
    color: var(--clr-navy);
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__logo {
    color: var(--clr-navy);
    text-shadow: none;
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__logo span {
    color: var(--clr-text-mid);
  }
  #nav.is-home-nav:not(.is-scrolled) .nav__hamburger span {
    background: var(--clr-navy);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--gutter);
    max-width: calc(var(--max-width) + var(--gutter) * 2);
    margin: 0 auto;
    transition: padding 0.4s ease;
  }

  .nav__top-bar {
    background: var(--clr-navy);
    color: var(--clr-white);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 6px var(--gutter);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .nav__top-inner {
    max-width: calc(var(--max-width) + var(--gutter) * 2);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .nav__top-promo {
    font-weight: 700;
    color: #fff;
    flex: 1; /* Force equal structural width */
    text-align: right;
  }
  .nav__top-contact { 
    display: flex; 
    gap: var(--space-8); 
    flex: 1; /* Force equal structural width */
    justify-content: flex-start;
  }
  .nav__top-contact a { color: inherit; text-decoration: none; transition: color 0.2s; display: flex; align-items: center; }
  .nav__top-contact a:hover { color: var(--clr-gold); }

  @media (max-width: 960px) {
    .nav__top-bar { display: none; }
  }

  #nav.is-scrolled {
    background: var(--clr-navy);
    box-shadow: 0 2px 24px rgba(78, 72, 50, 0.25);
  }
  #nav.is-scrolled .nav__inner {
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .nav__logo-img {
    height: 50px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    transition: filter 0.4s ease;
  }

  .nav__logo {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--clr-white);
    letter-spacing: 0.01em;
    line-height: 1.1;
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
  }
  .nav__logo span {
    display: block;
    font-size: 0.55em;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--clr-gold);
    margin-top: 2px;
    text-shadow: none;
  }

  @media (max-width: 500px) {
    .nav__inner { padding: var(--space-3) var(--gutter); }
    .nav__logo { font-size: 1.15rem; }
    .nav__logo span { font-size: 0.48em; letter-spacing: 0.12em; margin-top: 1px; }
  }

  /* Flicker Effect */
  [data-flicker] {
    position: relative;
    animation: flicker-loop 4s infinite linear;
  }
  @keyframes flicker-loop {
    0%, 90%, 100% { opacity: 1; transform: translate(0); text-shadow: none; }
    91% { opacity: 0.8; transform: translate(-1px, 1px); text-shadow: 2px 0 var(--clr-gold), -2px 0 rgba(255,255,255,0.5); }
    93% { opacity: 1; transform: translate(1px, -1px); text-shadow: none; }
    95% { opacity: 0.9; transform: translate(-1px, -1px); text-shadow: 1px 0 var(--clr-gold); }
    97% { opacity: 1; transform: translate(1px, 1px); text-shadow: none; }
  }

  [data-flicker]:hover {
    animation: flicker-glitch 0.4s infinite linear;
  }
  @keyframes flicker-glitch {
    0%   { opacity: 1; transform: translate(0); text-shadow: none; }
    20%  { opacity: 0.8; transform: translate(-1px, 1px); text-shadow: 2px 0 var(--clr-gold), -2px 0 rgba(255,255,255,0.5); }
    40%  { opacity: 1; transform: translate(1px, -1px); text-shadow: none; }
    60%  { opacity: 0.9; transform: translate(-1px, -1px); text-shadow: 1px 0 var(--clr-gold); }
    80%  { opacity: 1; transform: translate(1px, 1px); text-shadow: none; }
    100% { opacity: 1; transform: translate(0); }
  }

  .nav__top-promo {
    font-weight: 700;
    color: #fff;
  }
  .link-gold {
    color: var(--clr-gold-dark);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.3s ease;
  }
  .link-gold:hover {
    color: #fff;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav__links a {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.12em;
    position: relative;
    transition: color 0.2s ease;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }
  .nav__links a:not(.nav__cta)::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--clr-gold);
    border-radius: 2px;
    transition: width 0.3s var(--ease-out-expo);
  }
  .nav__links a:not(.nav__cta):hover::after { width: 100%; }
  .nav__links a:not(.nav__cta):hover { color: var(--clr-white); }
  .nav__links a.nav__active { color: var(--clr-white); }
  .nav__links a.nav__active::after { width: 100%; background: var(--clr-gold); }

  .nav__cta {
    background: var(--clr-gold) !important;
    color: var(--clr-navy) !important;
    padding: 10px 22px !important;
    border-radius: var(--radius-pill) !important;
    font-weight: 600 !important;
    font-size: var(--text-xs) !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease !important;
    box-shadow: var(--shadow-gold) !important;
    text-shadow: none !important;
  }
  .nav__cta:hover {
    background: var(--clr-gold-light) !important;
    transform: translateY(-2px) !important;
  }

  .nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    cursor: pointer;
  }
  .nav__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--clr-white);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
  }
  .nav__hamburger.is-open span:first-child  { transform: rotate(45deg) translate(5px, 5px); }
  .nav__hamburger.is-open span:nth-child(2) { opacity: 0; width: 0; }
  .nav__hamburger.is-open span:last-child   { transform: rotate(-45deg) translate(5px, -5px); }

  @media (max-width: 860px) {
    .nav__links { display: none; }
    .nav__hamburger { display: flex; }
  }

  /* Mobile drawer */
  #nav-drawer {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: var(--clr-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  #nav-drawer.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .drawer__inner { text-align: center; }
  .drawer__inner ul { display: flex; flex-direction: column; gap: var(--space-8); }

  .drawer__link {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--clr-white);
    transition: color 0.2s ease;
  }
  .drawer__link:hover { color: var(--clr-gold); }
  .drawer__cta { color: var(--clr-gold) !important; font-style: italic; }

  .drawer__phone {
    margin-top: var(--space-12);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
  }
</style>

<script>
  const nav    = document.getElementById('nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const drawer = document.getElementById('nav-drawer')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('is-scrolled', window.scrollY > 60);
  }, { passive: true });

  toggle.addEventListener('click', () => {
    const open = toggle.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
    drawer.classList.toggle('is-open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    // Focus trap: move focus into drawer when open
    if (open) {
      const firstFocusable = drawer.querySelector<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])');
      firstFocusable?.focus();
      // Trap Tab/Shift+Tab inside drawer
      drawer.addEventListener('keydown', trapFocus);
    } else {
      drawer.removeEventListener('keydown', trapFocus);
      toggle.focus();
    }
  });

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const focusable = Array.from(
      drawer.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])')
    ).filter(el => !el.closest('[aria-hidden="true"]'));
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  drawer.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      toggle.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
    });
  });
</script>
